  // ==========================================
  // IDLE GARDEN SYSTEM - 1:1 SEED TO PLANT
  // ==========================================
  void processIdleGarden() {
    bool changed = false;
    final now = DateTime.now().millisecondsSinceEpoch;
    
    for (int i = 0; i < maxGardenSlots; i++) {
      final slot = gardenSlots[i];
      if (slot == null || !slot.isActive) continue;

      final seed = seeds[slot.seedId];
      final growTime = getGrowTime(seed.plantId).inSeconds;
      
      final elapsed = (now - slot.startTime) ~/ 1000;
      int possibleCycles = elapsed ~/ growTime;

      // Check gold for seeds (seed 0 is free)
      int affordableCycles = possibleCycles;
      if (seed.cost > 0) {
        int maxAffordable = gold ~/ seed.cost;
        affordableCycles = possibleCycles.clamp(0, maxAffordable);
      }

      // Apply cycles
      for (int c = 0; c < affordableCycles; c++) {
        if (seed.cost > 0) gold -= seed.cost;
        
        // 1:1 mapping - guaranteed plant
        storage[seed.plantId]++;
        slot.cyclesCompleted++;
        
        // Apply XP boost
        int xpGain = plants[seed.plantId].xpValue;
        double xpMult = getBoostMultiplier(BoostType.xp150, BoostType.xp200, 1.5, 2.0);
        xpGain = (xpGain * xpMult).round();
        
        gainXP(xpGain);
        changed = true;
      }

      if (affordableCycles > 0) {
        slot.startTime += affordableCycles * growTime * 1000;
      }

      // Stop if out of gold
      if (seed.cost > 0 && gold < seed.cost) {
        slot.isActive = false;
      }
    }

    if (changed) save();
  }

  double getGardenSlotProgress(int slotIndex) {
    final slot = gardenSlots[slotIndex];
