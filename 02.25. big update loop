  }

  void _showSpeedUpgradeDialog(BuildContext context) {
    final cost = game.getNextBrewSpeedCost();
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Upgrade Brewing Speed', style: TextStyle(color: MagicColors.fire)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text(
              'Current: Level ${game.brewSpeedLevel}',
              style: const TextStyle(color: MagicColors.textLight),
            ),
            Text(
              'Next: Level ${game.brewSpeedLevel + 1}',
              style: const TextStyle(color: MagicColors.textLight),
            ),
            const SizedBox(height: 16),
            Text(
              'Cost: $cost Gold',
              style: TextStyle(
                color: game.gold >= cost ? MagicColors.gold : Colors.red,
                fontSize: 18,
                fontWeight: FontWeight.bold,
              ),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: game.gold >= cost ? () {
              game.upgradeBrewSpeed();
              Navigator.pop(ctx);
            } : null,
            child: const Text('Upgrade'),
          ),
        ],
      ),
    );
  }

  Widget _buildCauldron(BuildContext context, int index) {
    if (index >= game.unlockedBrewSlots) {
      final costs = game.getBrewSlotUnlockCost(index);
      final goldCost = costs["gold"] ?? 0;
      final crystalCost = costs["crystal"] ?? 0;
      final canAffordGold = game.gold >= goldCost && goldCost > 0;
      final canAffordCrystal = game.crystals >= crystalCost && crystalCost > 0;
      final isFree = goldCost == 0 && crystalCost == 0;

      return GestureDetector(
        onTap: () => _showUnlockSlotDialog(context, index, goldCost, crystalCost),
        child: Container(
          width: 100,
          height: 140,
          decoration: BoxDecoration(
            color: Colors.grey.shade900,
            borderRadius: const BorderRadius.only(
              bottomLeft: Radius.circular(50),
              bottomRight: Radius.circular(50),
              topLeft: Radius.circular(20),
              topRight: Radius.circular(20),
            ),
            border: Border.all(
              color: (canAffordGold || canAffordCrystal || isFree)
                  ? MagicColors.crystal.withOpacity(0.6)
                  : Colors.grey.shade800,
              width: 3,
            ),
          ),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(Icons.lock, color: Colors.grey),
              const SizedBox(height: 8),
              if (isFree)
                const Text('FREE', style: TextStyle(color: MagicColors.leaf, fontSize: 10, fontWeight: FontWeight.bold))
              else if (goldCost > 0 || crystalCost > 0)
                Column(
                  children: [
                    if (goldCost > 0)
                      Text(
                        '$goldCost g',
                        style: TextStyle(
                          color: canAffordGold ? MagicColors.gold : Colors.grey,
                          fontSize: 10,
                        ),
                      ),
                    if (crystalCost > 0)
                      Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Text(
                            '$crystalCost',
                            style: TextStyle(
                              color: canAffordCrystal ? MagicColors.crystal : Colors.grey,
                              fontSize: 10,
                            ),
                          ),
                          const Icon(Icons.diamond, color: MagicColors.crystal, size: 10),
                        ],
                      ),
                  ],
                ),
            ],
          ),
        ),
      );
    }

    final slot = game.brewSlots[index];
    if (slot == null) {
      return GestureDetector(
        onTap: () => _showPotionSelection(context, index),
        child: Container(
          width: 100,
          height: 140,
          decoration: BoxDecoration(
            gradient: const LinearGradient(
              colors: [Color(0xFF4A3728), Color(0xFF2C1810)],
            ),
            borderRadius: const BorderRadius.only(
              bottomLeft: Radius.circular(50),
              bottomRight: Radius.circular(50),
              topLeft: Radius.circular(20),
              topRight: Radius.circular(20),
            ),
            border: Border.all(color: const Color(0xFF6B4423), width: 3),
            boxShadow: [
              BoxShadow(
                color: Colors.black.withOpacity(0.5),
                blurRadius: 10,
                offset: const Offset(0, 5),
              ),
            ],
          ),
          child: const Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              Icon(Icons.add_circle_outline, color: MagicColors.crystal, size: 32),
              SizedBox(height: 8),
              Text('Select\\nPotion', textAlign: TextAlign.center, style: TextStyle(color: MagicColors.textMuted, fontSize: 10)),
            ],
          ),
        ),
      );
    }

    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return const SizedBox.shrink();

    final progress = game.getBrewSlotProgress(index);

    return GestureDetector(
      onTap: () => _showBrewStats(context, index),
      child: Container(
        width: 100,
        height: 140,
        decoration: BoxDecoration(
          gradient: LinearGradient(
            colors: [
              rarityColor(recipe.rarity).withOpacity(0.3),
              const Color(0xFF2C1810),
            ],
          ),
          borderRadius: const BorderRadius.only(
            bottomLeft: Radius.circular(50),
            bottomRight: Radius.circular(50),
            topLeft: Radius.circular(20),
            topRight: Radius.circular(20),
          ),
          border: Border.all(
            color: rarityColor(recipe.rarity),
            width: 3,
          ),
          boxShadow: [
            BoxShadow(
              color: rarityColor(recipe.rarity).withOpacity(0.3),
              blurRadius: 15,
            ),
          ],
        ),
        child: Stack(
          children: [
            ClipRRect(
              borderRadius: const BorderRadius.only(
                bottomLeft: Radius.circular(50),
                bottomRight: Radius.circular(50),
                topLeft: Radius.circular(20),
                topRight: Radius.circular(20),
              ),
              child: LinearProgressIndicator(
                value: progress,
                backgroundColor: Colors.transparent,
                valueColor: AlwaysStoppedAnimation<Color>(MagicColors.crystal.withOpacity(0.3)),
                minHeight: 140,
              ),
            ),
            Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Text(recipe.icon, style: const TextStyle(fontSize: 32)),
                  const SizedBox(height: 4),
                  Text(
                    recipe.name,
                    style: TextStyle(
                      color: MagicColors.textLight,
                      fontSize: 10,
                      fontWeight: FontWeight.bold,
                      shadows: [Shadow(color: rarityColor(recipe.rarity), blurRadius: 4)],
                    ),
                    textAlign: TextAlign.center,
                    maxLines: 2,
                    overflow: TextOverflow.ellipsis,
                  ),
                  const SizedBox(height: 4),
                  Text(
                    game.getBrewSlotTimeLeft(index),
                    style: const TextStyle(color: MagicColors.textMuted, fontSize: 9),
                  ),
                ],
              ),
            ),
            Positioned(
              top: 8,
              right: 8,
              child: GestureDetector(
                onTap: () => game.stopIdleBrew(index),
                child: Container(
                  padding: const EdgeInsets.all(2),
                  decoration: BoxDecoration(
                    color: Colors.red.withOpacity(0.3),
                    shape: BoxShape.circle,
                  ),
                  child: const Icon(Icons.close, color: Colors.red, size: 14),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }

  void _showUnlockSlotDialog(BuildContext context, int index, int goldCost, int crystalCost) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('Unlock Brew Slot ${index + 1}', style: const TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('Choose payment method:', style: TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 16),
            if (goldCost > 0)
              ListTile(
                leading: const Icon(Icons.monetization_on, color: MagicColors.gold),
                title: Text('$goldCost Gold', style: const TextStyle(color: MagicColors.textLight)),
                trailing: game.gold >= goldCost
                    ? ElevatedButton(
                        onPressed: () {
                          game.unlockBrewSlotWithGold();
                          Navigator.pop(ctx);
                        },
                        child: const Text('Buy'),
                      )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
            if (crystalCost > 0)
              ListTile(
                leading: const Icon(Icons.diamond, color: MagicColors.crystal),
                title: Text('$crystalCost Crystals', style: const TextStyle(color: MagicColors.textLight)),
                trailing: game.crystals >= crystalCost
                    ? ElevatedButton(
                        onPressed: () {
                          game.unlockBrewSlotWithCrystals();
                          Navigator.pop(ctx);
                        },
                        child: const Text('Buy'),
                      )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
        ],
      ),
    );
  }

  void _showPotionSelection(BuildContext context, int slotIndex) {
    final unlockedRecipes = allRecipes.where((r) => game.isRecipeUnlocked(r.key)).toList();

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Potion', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          height: 400,
          child: ListView.builder(
            itemCount: unlockedRecipes.length,
            itemBuilder: (context, index) {
              final recipe = unlockedRecipes[index];
              final brewTime = game.getBrewTime(recipe);
              bool hasMaterials = game.storage[recipe.plantTier] >= 3;

              return ListTile(
                leading: Text(recipe.icon, style: const TextStyle(fontSize: 28)),
                title: Text(recipe.name, style: TextStyle(color: hasMaterials ? MagicColors.textLight : Colors.grey)),
                subtitle: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      children: [
                        Container(
                          margin: const EdgeInsets.only(right: 2),
                          padding: const EdgeInsets.all(2),
                          decoration: BoxDecoration(
                            color: plants[recipe.plantTier].color.withOpacity(0.3),
                            borderRadius: BorderRadius.circular(4),
                          ),
                          child: Text('${plants[recipe.plantTier].icon} x3', style: const TextStyle(fontSize: 12)),
                        ),
                      ],
                    ),
                    Text(
                      '${recipe.sellPrice}g • ${formatDuration(brewTime)} • ${recipe.xpValue} XP',
                      style: TextStyle(color: hasMaterials ? MagicColors.gold : Colors.red, fontSize: 11),
                    ),
                  ],
                ),
                trailing: Container(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: rarityColor(recipe.rarity).withOpacity(0.3),
                    borderRadius: BorderRadius.circular(8),
                  ),
                  child: Text(
                    recipe.rarity.name.toUpperCase(),
                    style: TextStyle(
                      color: rarityColor(recipe.rarity),
                      fontSize: 9,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ),
                onTap: hasMaterials ? () {
                  game.startIdleBrew(slotIndex, recipe.key);
                  Navigator.pop(ctx);
                } : null,
              );
            },
          ),
        ),
      ),
    );
  }

  void _showBrewStats(BuildContext context, int index) {
    final slot = game.brewSlots[index];
    if (slot == null) return;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return;

    final goldPerHour = game.getBrewGoldPerHour(index);

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text(recipe.name, style: TextStyle(color: rarityColor(recipe.rarity))),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('Cycles: ${slot.cyclesCompleted}', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 12),
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: MagicColors.gold.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: MagicColors.gold),
              ),
              child: Column(
                children: [
                  const Text('Gold/Hour', style: TextStyle(color: MagicColors.textMuted, fontSize: 12)),
                  Text(
                    '${_formatNumber(goldPerHour.round())}',
                    style: const TextStyle(
                      color: MagicColors.gold,
                      fontSize: 24,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                  Text(
                    '${recipe.sellPrice}g per potion',
                    style: const TextStyle(color: MagicColors.gold, fontSize: 11),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 12),
            Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: plants[recipe.plantTier].color.withOpacity(0.2),
                borderRadius: BorderRadius.circular(8),
              ),
              child: Row(
                mainAxisSize: MainAxisSize.min,
                children: [
                  Text(plants[recipe.plantTier].icon),
                  const SizedBox(width: 4),
                  Text('${plants[recipe.plantTier].name} x3', style: const TextStyle(fontSize: 12)),
                ],
              ),
            ),
            Text(
              'Time: ${formatDuration(game.getBrewTime(recipe))}',
              style: const TextStyle(color: MagicColors.textMuted),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }

  Widget _buildInventory() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: MagicColors.surface.withOpacity(0.5),
        borderRadius: BorderRadius.circular(16),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Ingredients (need x3 for potions)',
            style: TextStyle(color: MagicColors.textLight, fontWeight: FontWeight.bold),
          ),
          const SizedBox(height: 12),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: plants.map((plant) {
              final count = game.storage[plant.id];
              if (count == 0) return const SizedBox.shrink();
              final canBrew = count >= 3;
              return Container(
                padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                decoration: BoxDecoration(
                  color: plant.color.withOpacity(canBrew ? 0.3 : 0.1),
                  borderRadius: BorderRadius.circular(20),
                  border: Border.all(color: plant.color.withOpacity(canBrew ? 0.8 : 0.3)),
                ),
                child: Row(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Text(plant.icon),
                    const SizedBox(width: 4),
                    Text(
                      '${plant.name}: $count',
                      style: TextStyle(
                        color: canBrew ? plant.color : Colors.grey,
                        fontSize: 12,
                        fontWeight: FontWeight.bold
                      ),
                    ),
                  ],
                ),
              );
            }).toList(),
          ),
        ],
      ),
    );
  }

  String _formatNumber(int n) {
    if (n >= 1000000) return '${(n/1000000).toStringAsFixed(1)}M';
    if (n >= 1000) return '${(n/1000).toStringAsFixed(1)}k';
    return n.toString();
  }
}

