  // ==========================================
  // SPEED UPGRADE SYSTEM
  // ==========================================
  
  // Get cost for next grow speed upgrade (average of all unlocked seeds)
  int getNextGrowSpeedCost() {
    if (growSpeedLevel >= 10) return -1; // Max level
    
    int totalCost = 0;
    int count = 0;
    for (int i = 0; i < seeds.length; i++) {
      if (level >= seeds[i].unlockLevel) {
        totalCost += growSpeedCosts[i][growSpeedLevel];
        count++;
      }
    }
    return count > 0 ? (totalCost / count).round() : growSpeedCosts[0][growSpeedLevel];
  }

  // Get cost for next brew speed upgrade (average of all unlocked potions)
  int getNextBrewSpeedCost() {
    if (brewSpeedLevel >= 10) return -1;
    
    int totalCost = 0;
    int count = 0;
    for (int i = 0; i < allRecipes.length; i++) {
      if (level >= allRecipes[i].unlockLevel) {
        totalCost += brewSpeedCosts[i][brewSpeedLevel];
        count++;
      }
    }
    return count > 0 ? (totalCost / count).round() : brewSpeedCosts[0][brewSpeedLevel];
  }

  void upgradeGrowSpeed() {
    if (growSpeedLevel >= 10) return;
    int cost = getNextGrowSpeedCost();
    if (cost < 0) return;
    if (gold >= cost) {
      gold -= cost;
      growSpeedLevel++;
      initShop();
      save();
      notifyListeners();
    }
  }

  void upgradeBrewSpeed() {
    if (brewSpeedLevel >= 10) return;
    int cost = getNextBrewSpeedCost();
    if (cost < 0) return;
    if (gold >= cost) {
      gold -= cost;
      brewSpeedLevel++;
      initShop();
      save();
      notifyListeners();
    }
  }

