                  ),
                ],
              ),
            ),
            const SizedBox(height: 8),
            Text(
              'Brew Speed: ${(game.getBrewSpeedMultiplier() * 100).toStringAsFixed(0)}% (Lvl ${game.brewSpeedLevel})',
