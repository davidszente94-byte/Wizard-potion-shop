  // ==========================================
  // IDLE BREW SYSTEM
  // ==========================================
  void processIdleBrew() {
    bool changed = false;
    final now = DateTime.now().millisecondsSinceEpoch;

    for (int i = 0; i < maxBrewSlots; i++) {
      final slot = brewSlots[i];
      if (slot == null || !slot.isActive) continue;

      final recipe = getRecipeByKey(slot.recipeKey);
      if (recipe == null) continue;

      final brewTime = getBrewTime(recipe).inSeconds;
      final elapsed = (now - slot.startTime) ~/ 1000;
      int possibleCycles = elapsed ~/ brewTime;

      // Check materials (3 of same plant)
      int plantId = recipe.plantTier;
      int available = storage[plantId] ~/ 3;
      int affordableCycles = possibleCycles.clamp(0, available);

      for (int c = 0; c < affordableCycles; c++) {
        storage[plantId] -= 3;

        int sellPrice = recipe.sellPrice;

        // Apply gold boost
        double goldMult = getBoostMultiplier(BoostType.gold150, BoostType.gold200, 1.5, 2.0);
        sellPrice = (sellPrice * goldMult).round();

        gold += sellPrice;

        int xpGain = recipe.xpValue;
        // Apply XP boost
        double xpMult = getBoostMultiplier(BoostType.xp150, BoostType.xp200, 1.5, 2.0);
        xpGain = (xpGain * xpMult).round();

        gainXP(xpGain);

        slot.cyclesCompleted++;
        changed = true;
      }

      if (affordableCycles > 0) {
        slot.startTime += affordableCycles * brewTime * 1000;
      }

      if (storage[recipe.plantTier] < 3) slot.isActive = false;
    }

    if (changed) {
      save();
      notifyListeners();
    }
  }

