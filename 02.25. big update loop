  factory IdleGardenSlot.fromJson(Map<String, dynamic> json) {
    return IdleGardenSlot(
      seedId: json["seedId"],
      startTime: json["start"],
      cyclesCompleted: json["cycles"] ?? 0,
      isActive: json["active"] ?? true,
    );
  }
}

