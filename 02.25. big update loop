            ),
            const SizedBox(height: 4),
            const Text(
              'Select potion to brew continuously',
              style: TextStyle(color: MagicColors.textMuted, fontSize: 12),
            ),
            const SizedBox(height: 12),
            // Speed upgrade button
            if (game.brewSpeedLevel < 10)
              ElevatedButton.icon(
                onPressed: () => _showSpeedUpgradeDialog(context),
                icon: const Icon(Icons.local_fire_department, size: 18),
                label: Text('Upgrade Speed (Lvl ${game.brewSpeedLevel + 1})'),
                style: ElevatedButton.styleFrom(
                  backgroundColor: MagicColors.fire.withOpacity(0.3),
                  foregroundColor: MagicColors.fire,
