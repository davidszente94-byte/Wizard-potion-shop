            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: game.gold >= cost ? () {
              game.upgradeGrowSpeed();
              Navigator.pop(ctx);
            } : null,
            child: const Text('Upgrade'),
          ),
        ],
      ),
    );
  }

  Widget _buildGardenPlot(BuildContext context, int index) {
    if (index >= game.unlockedSlots) {
      final costs = game.getGardenSlotUnlockCost(index);
      final goldCost = costs["gold"] ?? 0;
      final crystalCost = costs["crystal"] ?? 0;
      final canAffordGold = game.gold >= goldCost && goldCost > 0;
      final canAffordCrystal = game.crystals >= crystalCost && crystalCost > 0;
      final isFree = goldCost == 0 && crystalCost == 0;

      return GestureDetector(
        onTap: () => _showUnlockSlotDialog(context, index, goldCost, crystalCost),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            color: Colors.black26,
            borderRadius: BorderRadius.circular(16),
            border: Border.all(
              color: (canAffordGold || canAffordCrystal || isFree)
                  ? MagicColors.crystal.withOpacity(0.6)
                  : Colors.grey.withOpacity(0.3),
              width: 2,
            ),
          ),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(Icons.lock_open, color: Colors.grey),
              const SizedBox(height: 4),
              if (isFree)
                const Text('FREE', style: TextStyle(color: MagicColors.leaf, fontSize: 10, fontWeight: FontWeight.bold))
              else if (goldCost > 0 || crystalCost > 0)
                Column(
                  children: [
                    if (goldCost > 0)
                      Text(
                        '$goldCost g',
                        style: TextStyle(
                          color: canAffordGold ? MagicColors.gold : Colors.grey,
                          fontSize: 10,
                        ),
                      ),
                    if (crystalCost > 0)
                      Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Text(
                            '$crystalCost',
                            style: TextStyle(
                              color: canAffordCrystal ? MagicColors.crystal : Colors.grey,
                              fontSize: 10,
                            ),
                          ),
                          const Icon(Icons.diamond, color: MagicColors.crystal, size: 10),
                        ],
                      ),
                  ],
                )
              else
                const Text('LOCKED', style: TextStyle(color: Colors.grey, fontSize: 10)),
            ],
          ),
        ),
      );
    }

    final slot = game.gardenSlots[index];
    if (slot == null) {
      return GestureDetector(
        onTap: () => _showSeedSelection(context, index),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            gradient: LinearGradient(
              colors: [
                MagicColors.earth.withOpacity(0.6),
                MagicColors.earthLight.withOpacity(0.4),
              ],
            ),
            borderRadius: BorderRadius.circular(16),
            border: Border.all(color: MagicColors.leaf.withOpacity(0.5)),
          ),
          child: const Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              Icon(Icons.add, color: MagicColors.leafLight),
              SizedBox(height: 4),
              Text('Plant', style: TextStyle(color: MagicColors.textMuted, fontSize: 10)),
            ],
          ),
        ),
      );
    }

    final seed = seeds[slot.seedId];
    final progress = game.getGardenSlotProgress(index);
    final isReady = progress >= 1;

    return GestureDetector(
      onTap: () => _showSlotStats(context, index),
      child: Container(
        width: 80,
        height: 100,
        decoration: BoxDecoration(
          gradient: LinearGradient(
            colors: [
              seed.color.withOpacity(0.4),
              seed.color.withOpacity(0.1),
            ],
          ),
          borderRadius: BorderRadius.circular(16),
          border: Border.all(color: seed.color.withOpacity(0.6), width: 2),
        ),
        child: Stack(
          children: [
            ClipRRect(
              borderRadius: BorderRadius.circular(16),
              child: LinearProgressIndicator(
                value: progress,
                backgroundColor: Colors.transparent,
                valueColor: AlwaysStoppedAnimation<Color>(seed.color.withOpacity(0.3)),
                minHeight: 100,
              ),
            ),
            Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Text(seed.icon, style: const TextStyle(fontSize: 28)),
                  const SizedBox(height: 4),
                  Text(
                    seed.name.split(' ')[0],
                    style: const TextStyle(color: MagicColors.textLight, fontSize: 9),
                    textAlign: TextAlign.center,
                  ),
                  if (!isReady)
                    Text(
                      game.getGardenSlotTimeLeft(index),
                      style: const TextStyle(color: MagicColors.textMuted, fontSize: 10),
                    ),
                ],
              ),
            ),
            Positioned(
              top: 4,
              right: 4,
              child: GestureDetector(
                onTap: () => game.stopIdleGarden(index),
                child: Container(
                  padding: const EdgeInsets.all(2),
                  decoration: BoxDecoration(
                    color: Colors.red.withOpacity(0.3),
                    shape: BoxShape.circle,
                  ),
                  child: const Icon(Icons.close, color: Colors.red, size: 14),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }

  void _showUnlockSlotDialog(BuildContext context, int index, int goldCost, int crystalCost) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('Unlock Garden Slot ${index + 1}', style: const TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('Choose payment method:', style: TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 16),
            if (goldCost > 0)
              ListTile(
                leading: const Icon(Icons.monetization_on, color: MagicColors.gold),
                title: Text('$goldCost Gold', style: const TextStyle(color: MagicColors.textLight)),
                trailing: game.gold >= goldCost
                    ? ElevatedButton(
                        onPressed: () {
                          game.unlockGardenSlotWithGold();
                          Navigator.pop(ctx);
                        },
                        child: const Text('Buy'),
                      )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
            if (crystalCost > 0)
              ListTile(
                leading: const Icon(Icons.diamond, color: MagicColors.crystal),
                title: Text('$crystalCost Crystals', style: const TextStyle(color: MagicColors.textLight)),
                trailing: game.crystals >= crystalCost
                    ? ElevatedButton(
                        onPressed: () {
                          game.unlockGardenSlotWithCrystals();
                          Navigator.pop(ctx);
                        },
                        child: const Text('Buy'),
                      )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
        ],
      ),
    );
  }

  void _showSeedSelection(BuildContext context, int slotIndex) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Seed', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          child: ListView(
            shrinkWrap: true,
            children: seeds.map((s) {
              final unlocked = game.isSeedUnlocked(s.id);
              final canAfford = s.cost == 0 || game.gold >= s.cost;
              final growTime = game.getGrowTime(s.plantId);

              if (!unlocked) {
                return ListTile(
                  leading: const Icon(Icons.lock, color: Colors.grey),
                  title: Text(s.name, style: const TextStyle(color: Colors.grey)),
                  subtitle: Text('Unlocks at Level ${s.unlockLevel}', style: const TextStyle(color: Colors.grey)),
                );
              }

              return ListTile(
                leading: Text(s.icon, style: const TextStyle(fontSize: 24)),
                title: Text(s.name, style: TextStyle(color: canAfford ? MagicColors.textLight : Colors.grey)),
                subtitle: Text(
                  s.cost == 0 ? 'Free • ${plants[s.plantId].xpValue} XP' : '${s.cost}g/cycle • ${plants[s.plantId].xpValue} XP',
                  style: TextStyle(color: canAfford ? MagicColors.textMuted : Colors.red),
                ),
                trailing: Text(
                  formatDuration(growTime),
                  style: TextStyle(color: s.color, fontWeight: FontWeight.bold),
                ),
                onTap: canAfford ? () {
                  game.startIdleGarden(slotIndex, s.id);
                  Navigator.pop(ctx);
                } : null,
              );
            }).toList(),
          ),
        ),
      ),
    );
  }

  void _showSlotStats(BuildContext context, int index) {
    final slot = game.gardenSlots[index];
    if (slot == null) return;
    final seed = seeds[slot.seedId];
    final plantsPerHour = game.getGardenPlantsPerHour(index);

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('${seed.name}', style: TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('Cycles: ${slot.cyclesCompleted}', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 8),
            Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: seed.color.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Column(
                children: [
                  const Text('Production', style: TextStyle(color: MagicColors.textMuted, fontSize: 12)),
                  Text(
                    '${plantsPerHour.toStringAsFixed(1)}/hour',
                    style: TextStyle(
                      color: seed.color,
                      fontSize: 20,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                  Text(
                    'Guaranteed: ${plants[slot.seedId].name}',
                    style: TextStyle(color: seed.color.withOpacity(0.8), fontSize: 11),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 8),
            Text(
              'Cost: ${seed.cost}g • Time: ${formatDuration(game.getGrowTime(seed.plantId))}',
              style: const TextStyle(color: MagicColors.textMuted),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }

  Widget _buildInventory(BuildContext context) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: MagicColors.surface.withOpacity(0.6),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: MagicColors.leaf.withOpacity(0.3)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Row(
            children: [
              Icon(Icons.inventory_2, color: MagicColors.leaf),
              SizedBox(width: 8),
              Text(
                'Plant Storage (Tap to sell all)',
                style: TextStyle(color: MagicColors.textLight, fontWeight: FontWeight.bold),
              ),
            ],
          ),
          const SizedBox(height: 12),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: plants.map((plant) {
              final count = game.storage[plant.id];
              if (count == 0) return const SizedBox.shrink();
              return GestureDetector(
                onTap: () => _showSellAllDialog(context, plant),
                child: Container(
                  padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
                  decoration: BoxDecoration(
                    color: plant.color.withOpacity(0.2),
                    borderRadius: BorderRadius.circular(16),
                    border: Border.all(color: plant.color.withOpacity(0.5)),
                  ),
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Text(plant.icon),
                      const SizedBox(width: 6),
                      Text(plant.name, style: TextStyle(color: plant.color, fontSize: 12)),
                      const SizedBox(width: 6),
                      Container(
                        padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                        decoration: BoxDecoration(
                          color: Colors.black26,
                          borderRadius: BorderRadius.circular(10),
                        ),
                        child: Text('x$count', style: const TextStyle(color: MagicColors.textLight, fontSize: 10)),
                      ),
                    ],
                  ),
                ),
              );
            }).toList(),
          ),
        ],
      ),
    );
  }

  void _showSellAllDialog(BuildContext context, Plant plant) {
    final count = game.storage[plant.id];
    final totalValue = count * plant.sellPrice;

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('Sell All ${plant.name}?', style: TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('You have $count ${plant.name}(s)', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 16),
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: MagicColors.gold.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  const Icon(Icons.monetization_on, color: MagicColors.gold),
                  const SizedBox(width: 8),
                  Text(
                    '+${game.getBoostMultiplier(BoostType.gold150, BoostType.gold200, 1.5, 2.0) > 1.0 ? "(Boosted!) " : ""}$totalValue Gold',
                    style: const TextStyle(
                      color: MagicColors.gold,
                      fontSize: 20,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ],
              ),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () {
              final earned = game.sellAllPlants(plant.id);
              Navigator.pop(ctx);
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(
                  content: Text('Sold for $earned Gold!'),
                  backgroundColor: MagicColors.gold,
                ),
              );
            },
            style: ElevatedButton.styleFrom(backgroundColor: MagicColors.gold, foregroundColor: Colors.black),
            child: const Text('SELL ALL'),
          ),
        ],
      ),
    );
  }
}
