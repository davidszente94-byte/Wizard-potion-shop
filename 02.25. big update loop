class RecipeBookScreen extends StatelessWidget {
  final GameState game;
  const RecipeBookScreen(this.game, {super.key});

  @override
  Widget build(BuildContext context) {
    return Container(
      decoration: BoxDecoration(
        gradient: LinearGradient(
          begin: Alignment.topCenter,
          end: Alignment.bottomCenter,
          colors: [
            const Color(0xFF1A1A2E),
            MagicColors.background,
          ],
        ),
      ),
      child: ListView(
        padding: const EdgeInsets.all(16),
        children: [
          const Center(
            child: Text(
              '📜 Recipe Book',
              style: TextStyle(color: MagicColors.gold, fontSize: 24, fontWeight: FontWeight.bold),
            ),
          ),
          const SizedBox(height: 8),
          Center(
            child: Text(
              '7 Core Potions - 3 of each plant tier',
              style: TextStyle(color: MagicColors.textMuted.withOpacity(0.8)),
            ),
          ),
          const SizedBox(height: 20),
          ...allRecipes.map((recipe) => _buildRecipeCard(recipe)),
        ],
      ),
    );
  }

  Widget _buildRecipeCard(Recipe recipe) {
    final isUnlocked = game.isRecipeUnlocked(recipe.key);
    final color = isUnlocked ? rarityColor(recipe.rarity) : Colors.grey;

    return Container(
      margin: const EdgeInsets.only(bottom: 12),
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        gradient: LinearGradient(
          colors: isUnlocked
              ? [color.withOpacity(0.2), Colors.transparent]
              : [Colors.grey.withOpacity(0.1), Colors.transparent],
        ),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(
          color: isUnlocked ? color : Colors.grey.withOpacity(0.3),
        ),
      ),
      child: Row(
        children: [
          Container(
            width: 50,
            height: 50,
            decoration: BoxDecoration(
              color: isUnlocked ? color.withOpacity(0.2) : Colors.grey.withOpacity(0.1),
              shape: BoxShape.circle,
            ),
            child: Center(
              child: Text(
                isUnlocked ? recipe.icon : '🔒',
                style: const TextStyle(fontSize: 24),
              ),
            ),
          ),
          const SizedBox(width: 16),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  isUnlocked ? recipe.name : '???',
                  style: TextStyle(
                    color: isUnlocked ? MagicColors.textLight : Colors.grey,
                    fontWeight: FontWeight.bold,
                    fontSize: 16,
                  ),
                ),
                const SizedBox(height: 4),
                if (isUnlocked) ...[
                  Row(
                    children: [
                      Container(
                        margin: const EdgeInsets.only(right: 4),
                        padding: const EdgeInsets.all(4),
                        decoration: BoxDecoration(
                          color: plants[recipe.plantTier].color.withOpacity(0.3),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: Text('${plants[recipe.plantTier].icon} x3'),
                      ),
                      Text(
                        plants[recipe.plantTier].name,
                        style: TextStyle(color: plants[recipe.plantTier].color, fontSize: 12),
                      ),
                    ],
                  ),
                  const SizedBox(height: 4),
                  Row(
                    children: [
                      Container(
                        padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                        decoration: BoxDecoration(
                          color: color.withOpacity(0.2),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: Text(
                          recipe.rarity.name.toUpperCase(),
                          style: TextStyle(color: color, fontSize: 10, fontWeight: FontWeight.bold),
                        ),
                      ),
                      const SizedBox(width: 8),
                      Text(
                        '${recipe.sellPrice}g • ${recipe.xpValue} XP',
                        style: const TextStyle(color: MagicColors.textMuted, fontSize: 11),
                      ),
                    ],
                  ),
                ] else
                  Text(
                    'Unlocks at Level ${recipe.unlockLevel}',
                    style: TextStyle(
                      color: game.level >= recipe.unlockLevel ? MagicColors.leaf : Colors.grey,
                      fontSize: 12,
                    ),
                  ),
              ],
            ),
          ),
          if (isUnlocked)
            const Icon(Icons.check_circle, color: Colors.green)
          else
            Icon(Icons.lock, color: game.level >= recipe.unlockLevel ? MagicColors.leaf : Colors.grey),
        ],
      ),
    );
  }
}

Color rarityColor(Rarity r) {
  switch (r) {
    case Rarity.common: return MagicColors.common;
    case Rarity.rare: return MagicColors.rare;
    case Rarity.epic: return MagicColors.epic;
  }
}




