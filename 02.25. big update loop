  List<String> buyShopItemWithPopup(ShopItem item) {
    resetDailyPurchases();

    // Check daily limit
    if (item.isDailyLimited && !canBuyDailyItem(item.id)) {
      return ["Daily limit reached for this item!"];
    }

    if (item.currency == ShopCurrency.gold) {
      if (gold < item.price) return ["Not enough gold!"];
      gold -= item.price;
    } else {
      if (crystals < item.price) return ["Not enough crystals!"];
      crystals -= item.price;
    }

    item.onBuy(this);
    save();
    notifyListeners();
    return ["Acquired: ${item.name}"];
  }

  // ==========================================
  // SELL ALL PLANTS
  // ==========================================
  int sellAllPlants(int plantId) {
    final count = storage[plantId];
    if (count <= 0) return 0;

    final totalGold = count * plants[plantId].sellPrice;

    // Apply gold boost
    double goldMult = getBoostMultiplier(BoostType.gold150, BoostType.gold200, 1.5, 2.0);
    final finalGold = (totalGold * goldMult).round();

    gold += finalGold;
    storage[plantId] = 0;
    save();
    notifyListeners();
    return finalGold;
  }

  // ==========================================
  // SAVE/LOAD
  // ==========================================
  Future<void> load() async {
    prefs = await SharedPreferences.getInstance();
    gold = prefs.getInt("gold") ?? 0;
    crystals = prefs.getInt("crystals") ?? 0;
    unlockedSlots = prefs.getInt("unlockedSlots") ?? 1;
    unlockedBrewSlots = prefs.getInt("unlockedBrewSlots") ?? 1;
    growSpeedLevel = prefs.getInt("growSpeedLevel") ?? 1;
    brewSpeedLevel = prefs.getInt("brewSpeedLevel") ?? 1;
    level = prefs.getInt("level") ?? 1;
    xp = prefs.getInt("xp") ?? 0;
    lastSaveTime = prefs.getInt("lastSaveTime") ?? DateTime.now().millisecondsSinceEpoch;
    lastLoginDay = prefs.getInt("lastLoginDay") ?? 0;
    consecutiveLogins = prefs.getInt("consecutiveLogins") ?? 0;
    lastShopResetDay = prefs.getInt("lastShopResetDay") ?? 0;

    // Load boosts
    final boostsJson = prefs.getString("activeBoosts");
    if (boostsJson != null) {
      try {
        final List<dynamic> decoded = jsonDecode(boostsJson);
        activeBoosts = decoded.map((j) => ActiveBoost.fromJson(j)).toList();
      } catch (e) {
        activeBoosts = [];
      }
    }

    // Load daily purchases
    final dailyJson = prefs.getString("dailyPurchases");
    if (dailyJson != null) {
      try {
        dailyPurchases = Map<String, int>.from(jsonDecode(dailyJson));
      } catch (e) {
        dailyPurchases = {};
      }
    }

    for (int i = 0; i < plants.length; i++) {
      storage[i] = prefs.getInt("storage_$i") ?? 0;
    }
    for (int i = 0; i < seeds.length; i++) {
      seedStorage[i] = prefs.getInt("seeds_$i") ?? 0;
    }

    for (int i = 0; i < maxGardenSlots; i++) {
      String? data = prefs.getString("garden_$i");
      if (data != null) {
        try {
          gardenSlots[i] = IdleGardenSlot.fromJson(jsonDecode(data));
        } catch (e) {
          gardenSlots[i] = null;
        }
      }
    }

    for (int i = 0; i < maxBrewSlots; i++) {
      String? data = prefs.getString("brew_$i");
      if (data != null) {
        try {
          brewSlots[i] = IdleBrewSlot.fromJson(jsonDecode(data));
        } catch (e) {
          brewSlots[i] = null;
        }
      }
    }

    // Check daily login
    checkDailyLogin();

    // Process offline progress (max 4 hours)
    processOfflineProgress();

    initShop();
    notifyListeners();
  }

  void checkDailyLogin() {
    final now = DateTime.now();
    final currentDay = now.year * 10000 + now.month * 100 + now.day;

    if (currentDay != lastLoginDay) {
      // New day - give reward
      final reward = getDailyLoginReward(level);
      gold += reward;

      // Check consecutive
      final yesterday = currentDay - 1;
      if (lastLoginDay == yesterday) {
        consecutiveLogins++;
      } else {
        consecutiveLogins = 1;
      }

      lastLoginDay = currentDay;
      save();

      // Show dialog will be handled by UI
    }
  }

  void processOfflineProgress() {
    final now = DateTime.now().millisecondsSinceEpoch;
    final offlineSeconds = ((now - lastSaveTime) ~/ 1000).clamp(0, maxIdleSeconds);

    if (offlineSeconds > 0) {
      // Simulate garden progress
      for (int i = 0; i < maxGardenSlots; i++) {
        final slot = gardenSlots[i];
        if (slot == null || !slot.isActive) continue;

        final seed = seeds[slot.seedId];
        final growTime = getGrowTime(seed.plantId).inSeconds;
        if (growTime <= 0) continue;

        int possibleCycles = offlineSeconds ~/ growTime;

        // Cap by gold
        if (seed.cost > 0) {
          int maxAffordable = gold ~/ seed.cost;
          possibleCycles = possibleCycles.clamp(0, maxAffordable);
        }

        for (int c = 0; c < possibleCycles; c++) {
          if (seed.cost > 0) gold -= seed.cost;
          storage[seed.plantId]++;
          slot.cyclesCompleted++;

          // XP with boost
          int xpGain = plants[seed.plantId].xpValue;
          double xpMult = getBoostMultiplier(BoostType.xp150, BoostType.xp200, 1.5, 2.0);
          xpGain = (xpGain * xpMult).round();
          gainXP(xpGain);
        }

        slot.startTime = now - (offlineSeconds % growTime) * 1000;
      }

      // Simulate brew progress
      for (int i = 0; i < maxBrewSlots; i++) {
        final slot = brewSlots[i];
        if (slot == null || !slot.isActive) continue;

        final recipe = getRecipeByKey(slot.recipeKey);
        if (recipe == null) continue;

        final brewTime = getBrewTime(recipe).inSeconds;
        if (brewTime <= 0) continue;

        int possibleCycles = offlineSeconds ~/ brewTime;

        int plantId = recipe.plantTier;
        int available = storage[plantId] ~/ 3;
        possibleCycles = possibleCycles.clamp(0, available);

        for (int c = 0; c < possibleCycles; c++) {
          storage[plantId] -= 3;

          int sellPrice = recipe.sellPrice;
          double goldMult = getBoostMultiplier(BoostType.gold150, BoostType.gold200, 1.5, 2.0);
          sellPrice = (sellPrice * goldMult).round();

          gold += sellPrice;
          slot.cyclesCompleted++;

          int xpGain = recipe.xpValue;
          double xpMult = getBoostMultiplier(BoostType.xp150, BoostType.xp200, 1.5, 2.0);
          xpGain = (xpGain * xpMult).round();
          gainXP(xpGain);
        }

        slot.startTime = now - (offlineSeconds % brewTime) * 1000;
      }
    }
  }

  Future<void> save() async {
    lastSaveTime = DateTime.now().millisecondsSinceEpoch;
    await prefs.setInt("gold", gold);
    await prefs.setInt("crystals", crystals);
    await prefs.setInt("unlockedSlots", unlockedSlots);
    await prefs.setInt("unlockedBrewSlots", unlockedBrewSlots);
    await prefs.setInt("growSpeedLevel", growSpeedLevel);
    await prefs.setInt("brewSpeedLevel", brewSpeedLevel);
    await prefs.setInt("level", level);
    await prefs.setInt("xp", xp);
    await prefs.setInt("lastSaveTime", lastSaveTime);
    await prefs.setInt("lastLoginDay", lastLoginDay);
    await prefs.setInt("consecutiveLogins", consecutiveLogins);
    await prefs.setInt("lastShopResetDay", lastShopResetDay);

    // Save boosts
    await prefs.setString("activeBoosts", jsonEncode(activeBoosts.map((b) => b.toJson()).toList()));
    await prefs.setString("dailyPurchases", jsonEncode(dailyPurchases));

    for (int i = 0; i < plants.length; i++) {
      await prefs.setInt("storage_$i", storage[i]);
    }
    for (int i = 0; i < seeds.length; i++) {
      await prefs.setInt("seeds_$i", seedStorage[i]);
    }

    for (int i = 0; i < maxGardenSlots; i++) {
      if (gardenSlots[i] != null) {
        await prefs.setString("garden_$i", jsonEncode(gardenSlots[i]!.toJson()));
      } else {
        await prefs.remove("garden_$i");
      }
    }

    for (int i = 0; i < maxBrewSlots; i++) {
      if (brewSlots[i] != null) {
        await prefs.setString("brew_$i", jsonEncode(brewSlots[i]!.toJson()));
      } else {
        await prefs.remove("brew_$i");
      }
    }
  }
}
