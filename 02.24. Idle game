  int getGardenSlotCost(int slotIndex) {
    // 0 free, 1=1000, 2=10000, 3=100000, 4=1000000, 5=5c, 6=10c, 7=15c, 8=20c, 9=20c
    const costs = [0, 1000, 10000, 100000, 1000000];
    if (slotIndex < costs.length) return costs[slotIndex];
    return -1; // Crystal costs handled separately
  }

  int getGardenSlotCrystalCost(int slotIndex) {
    const crystalCosts = [0, 0, 0, 0, 0, 5, 10, 15, 20, 20];
    if (slotIndex < crystalCosts.length) return crystalCosts[slotIndex];
    return -1;
  }

  void unlockGardenSlot() {
    if (unlockedSlots >= maxGardenSlots) return;
    int goldCost = getGardenSlotCost(unlockedSlots);
    int crystalCost = getGardenSlotCrystalCost(unlockedSlots);

    if (goldCost > 0 && gold >= goldCost) {
      gold -= goldCost;
    } else if (crystalCost > 0 && crystals >= crystalCost) {
      crystals -= crystalCost;
    } else {
      return;
    }

    unlockedSlots++;
    save();
    notifyListeners();
  }

  int getBrewSlotCost(int slotIndex) {
    const costs = [0, 1000, 10000, 100000, 1000000];
    if (slotIndex < costs.length) return costs[slotIndex];
    return -1;
  }

  int getBrewSlotCrystalCost(int slotIndex) {
    const crystalCosts = [0, 0, 0, 0, 0, 5, 10, 15, 20, 20];
    if (slotIndex < crystalCosts.length) return crystalCosts[slotIndex];
    return -1;
  }

  void unlockBrewSlot() {
