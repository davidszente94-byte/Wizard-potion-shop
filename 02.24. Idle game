      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Potion to Brew', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          height: 400,
          child: ListView.builder(
            itemCount: unlockedRecipes.length,
            itemBuilder: (context, index) {
              final recipe = unlockedRecipes[index];
              final price = game.calculatePotionSellPrice(recipe);
              final brewTime = game.getPotionBrewTime(recipe);

              // Check materials
              bool hasMaterials = true;
              for (int plantId in recipe.ids.toSet()) {
                int count = recipe.ids.where((id) => id == plantId).length;
                if (game.storage[plantId] < count) hasMaterials = false;
              }

              return ListTile(
                leading: Text(recipe.icon, style: const TextStyle(fontSize: 28)),
                title: Text(recipe.name, style: TextStyle(color: hasMaterials ? MagicColors.textLight : Colors.grey)),
                subtitle: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      children: recipe.ids.map((id) => Container(
                        margin: const EdgeInsets.only(right: 2),
                        padding: const EdgeInsets.all(2),
                        decoration: BoxDecoration(
                          color: plants[id].color.withOpacity(0.3),
                          borderRadius: BorderRadius.circular(4),
