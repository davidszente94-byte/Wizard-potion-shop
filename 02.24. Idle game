// ==========================================
// GAME STATE - IDLE TYCOON
// ==========================================
class GameState extends ChangeNotifier {
  List<ShopItem> shopItems = [];
  int gold = 0;
  int crystals = 0;
  int speedLevel = 0;
  int level = 1;
  int xp = 0;
  int instantBrewTokens = 0;
  int instantGrowTokens = 0;
  int doubleXpCharges = 0;
  int doubleGoldCharges = 0;
  double brewSpeed = 1.0;
  int unlockedSlots = 1; // Start with 1
  int unlockedBrewSlots = 1; // Start with 1
  int lastGoldGain = 0;
  int lastQuestGain = 0;
  bool showGoldAnimation = false;
  int lastSaveTime = 0;

  static const int maxGardenSlots = 10;
  static const int maxBrewSlots = 10;

  // Idle slots - new system
  List<IdleGardenSlot?> gardenSlots = List.generate(maxGardenSlots, (_) => null);
  List<IdleBrewSlot?> brewSlots = List.generate(maxBrewSlots, (_) => null);

  // Storage
  List<int> storage = List.generate(plants.length, (_) => 0);
  List<int> seedStorage = List.generate(seeds.length, (_) => 0);

  Timer? _ticker;
  late SharedPreferences prefs;

  // 4 hour idle cap in seconds
  static const int maxIdleSeconds = 4 * 60 * 60; // 14400 seconds

  void startTicker() {
    _ticker?.cancel();
    _ticker = Timer.periodic(const Duration(seconds: 1), (_) {
      processIdleGarden();
      processIdleBrew();
      notifyListeners();
    });
  }

  @override
  void dispose() {
    _ticker?.cancel();
    super.dispose();
  }

  // ==========================================
  // IDLE GARDEN SYSTEM
  // ==========================================
  void processIdleGarden() {
    bool changed = false;
    for (int i = 0; i < maxGardenSlots; i++) {
      final slot = gardenSlots[i];
      if (slot == null || !slot.isActive) continue;

      final seed = seeds[slot.seedId];
      final now = DateTime.now().millisecondsSinceEpoch;
      final elapsed = (now - slot.startTime) ~/ 1000;
      final growTime = seed.growTime.inSeconds;

      // Calculate how many cycles completed
      int possibleCycles = elapsed ~/ growTime;

      // Check if we have gold for seeds (seed 0 is free)
      int affordableCycles = possibleCycles;
      if (seed.cost > 0) {
        int maxAffordable = gold ~/ seed.cost;
        affordableCycles = possibleCycles.clamp(0, maxAffordable);
      }

      // Apply cycles
      for (int c = 0; c < affordableCycles; c++) {
        // Deduct seed cost
        if (seed.cost > 0) {
          gold -= seed.cost;
        }

        // Roll for plant
        double roll = Random().nextDouble();
        double sum = 0;
        int resultPlant = seed.results.first.plantId;
        for (var r in seed.results) {
          sum += r.chance;
          if (roll <= sum) {
            resultPlant = r.plantId;
            break;
          }
        }

        storage[resultPlant]++;
        slot.cyclesCompleted++;
        gainXP(getPlantXp(resultPlant));
        changed = true;
      }

      // Update start time for next cycle calculation
      if (affordableCycles > 0) {
        slot.startTime += affordableCycles * growTime * 1000;
      }

      // Stop if out of gold
      if (seed.cost > 0 && gold < seed.cost) {
        slot.isActive = false;
      }
    }

    if (changed) save();
  }

  double getGardenSlotProgress(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null) return 0;
    final seed = seeds[slot.seedId];
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) / 1000;
    return (elapsed / seed.growTime.inSeconds).clamp(0.0, 1.0);
  }

  String getGardenSlotTimeLeft(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null) return "";
    final seed = seeds[slot.seedId];
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) ~/ 1000;
    final remaining = seed.growTime.inSeconds - (elapsed % seed.growTime.inSeconds);
    return formatTime(remaining);
  }

  double getGardenPlantsPerHour(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null) return 0;
    final seed = seeds[slot.seedId];

    // Calculate expected plants per cycle
    double expectedPlants = 0;
    for (var result in seed.results) {
      expectedPlants += result.chance;
    }

    // Cycles per hour
    double cyclesPerHour = 3600 / seed.growTime.inSeconds;
    return expectedPlants * cyclesPerHour;
  }

  void startIdleGarden(int slotIndex, int seedId) {
    if (slotIndex >= unlockedSlots) return;
    gardenSlots[slotIndex] = IdleGardenSlot(
      seedId: seedId,
      startTime: DateTime.now().millisecondsSinceEpoch,
    );
    save();
    notifyListeners();
  }

  void stopIdleGarden(int slotIndex) {
    gardenSlots[slotIndex] = null;
    save();
    notifyListeners();
  }

  void useInstantGrow(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null || instantGrowTokens <= 0) return;

    final seed = seeds[slot.seedId];

    // Complete current cycle instantly
    double roll = Random().nextDouble();
    double sum = 0;
    int resultPlant = seed.results.first.plantId;
    for (var r in seed.results) {
      sum += r.chance;
      if (roll <= sum) {
        resultPlant = r.plantId;
        break;
      }
    }

    if (seed.cost > 0 && gold >= seed.cost) {
      gold -= seed.cost;
    } else if (seed.cost > 0) {
      return; // Can't afford seed
    }

    storage[resultPlant]++;
    slot.cyclesCompleted++;
    slot.startTime = DateTime.now().millisecondsSinceEpoch;
    instantGrowTokens--;
    gainXP(getPlantXp(resultPlant));
    save();
    notifyListeners();
  }

  // ==========================================
  // IDLE BREW SYSTEM
  // ==========================================
  void processIdleBrew() {
    bool changed = false;
    for (int i = 0; i < maxBrewSlots; i++) {
      final slot = brewSlots[i];
      if (slot == null || !slot.isActive) continue;

      final recipe = getRecipeByKey(slot.recipeKey);
      if (recipe == null) continue;

      final brewTime = getPotionBrewTime(recipe);
      final now = DateTime.now().millisecondsSinceEpoch;
      final elapsed = (now - slot.startTime) ~/ 1000;

      int possibleCycles = elapsed ~/ brewTime.inSeconds;

      // Check materials
      List<int> materials = List<int>.from(recipe.ids);
      int maxAffordable = 999999;
      for (int plantId in materials.toSet()) {
        int count = materials.where((id) => id == plantId).length;
        int available = storage[plantId] ~/ count;
        if (available < maxAffordable) maxAffordable = available;
      }

      int affordableCycles = possibleCycles.clamp(0, maxAffordable);

      for (int c = 0; c < affordableCycles; c++) {
        // Consume materials
        for (int plantId in materials) {
          storage[plantId]--;
        }

        // Sell potion automatically
        int sellPrice = calculatePotionSellPrice(recipe);
        if (doubleGoldCharges > 0) {
          sellPrice *= 2;
          doubleGoldCharges--;
        }
        gold += sellPrice;

        int xpGain = getPotionXp(recipe.rarity);
        if (doubleXpCharges > 0) {
          xpGain *= 2;
          doubleXpCharges--;
        }
        gainXP(xpGain);

        slot.cyclesCompleted++;
        changed = true;
      }

      if (affordableCycles > 0) {
        slot.startTime += affordableCycles * brewTime.inSeconds * 1000;
      }

      // Stop if out of materials
      bool hasMaterials = true;
      for (int plantId in materials.toSet()) {
        int count = materials.where((id) => id == plantId).length;
        if (storage[plantId] < count) {
          hasMaterials = false;
          break;
        }
      }
      if (!hasMaterials) slot.isActive = false;
    }

    if (changed) {
      save();
      notifyListeners();
    }
  }

  Duration getPotionBrewTime(Recipe recipe) {
    // Base time from 45s to 30min based on recipe complexity
    int sum = recipe.ids.reduce((a, b) => a + b);
    double baseSeconds = 45 + (sum / 18) * (30 * 60 - 45); // Linear interpolation
    return Duration(seconds: (baseSeconds / brewSpeed).round());
  }

  int calculatePotionSellPrice(Recipe recipe) {
    // 0+0+0 = 5 gold, 6+6+6 = 10000 gold
    int sum = recipe.ids.reduce((a, b) => a + b);
    if (sum == 0) return 5;
    if (sum == 18) return 10000;

    // Exponential curve between 5 and 10000
    double progress = sum / 18.0;
    double price = 5 * pow(10000 / 5, progress).toDouble();
    return price.round();
  }

  double getBrewSlotProgress(int slotIndex) {
    final slot = brewSlots[slotIndex];
    if (slot == null) return 0;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return 0;
    final brewTime = getPotionBrewTime(recipe);
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) / 1000;
    return (elapsed / brewTime.inSeconds).clamp(0.0, 1.0);
  }

  String getBrewSlotTimeLeft(int slotIndex) {
    final slot = brewSlots[slotIndex];
    if (slot == null) return "";
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return "";
    final brewTime = getPotionBrewTime(recipe);
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) ~/ 1000;
    final remaining = brewTime.inSeconds - (elapsed % brewTime.inSeconds);
    return formatTime(remaining);
  }

  double getBrewGoldPerHour(int slotIndex) {
    final slot = brewSlots[slotIndex];
    if (slot == null) return 0;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return 0;

    int price = calculatePotionSellPrice(recipe);
    double cyclesPerHour = 3600 / getPotionBrewTime(recipe).inSeconds;
    return price * cyclesPerHour;
  }

