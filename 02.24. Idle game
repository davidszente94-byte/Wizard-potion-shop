              : [Colors.grey.withOpacity(0.1), Colors.transparent],
        ),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(
          color: isUnlocked ? color : Colors.grey.withOpacity(0.3),
        ),
      ),
      child: Row(
        children: [
          Container(
            width: 50,
            height: 50,
            decoration: BoxDecoration(
              color: isUnlocked ? color.withOpacity(0.2) : Colors.grey.withOpacity(0.1),
              shape: BoxShape.circle,
            ),
            child: Center(
              child: Text(
                isUnlocked ? recipe.icon : '🔒',
                style: const TextStyle(fontSize: 24),
              ),
            ),
          ),
          const SizedBox(width: 16),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  isUnlocked ? recipe.name : 'Unknown Recipe',
                  style: TextStyle(
                    color: isUnlocked ? MagicColors.textLight : Colors.grey,
                    fontWeight: FontWeight.bold,
                    fontSize: 16,
                  ),
                ),
                const SizedBox(height: 4),
                if (isUnlocked) ...[
                  Row(
                    children: recipe.ids.map((id) => Container(
                      margin: const EdgeInsets.only(right: 4),
                      padding: const EdgeInsets.all(4),
                      decoration: BoxDecoration(
                        color: plants[id].color.withOpacity(0.3),
                        borderRadius: BorderRadius.circular(8),
                      ),
                      child: Text(plants[id].icon),
                    )).toList(),
                  ),
                  const SizedBox(height: 4),
                  Container(
                    padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                    decoration: BoxDecoration(
                      color: color.withOpacity(0.2),
                      borderRadius: BorderRadius.circular(8),
                    ),
                    child: Text(
                      recipe.rarity.name.toUpperCase(),
                      style: TextStyle(color: color, fontSize: 10, fontWeight: FontWeight.bold),
                    ),
                  ),
                ] else
                  Text(
                    'Unlocks at Level $canUnlockAt',
                    style: TextStyle(
                      color: game.level >= canUnlockAt ? MagicColors.leaf : Colors.grey,
                      fontSize: 12,
                    ),
                  ),
              ],
            ),
          ),
          if (isUnlocked)
            const Icon(Icons.check_circle, color: Colors.green)
          else
            Icon(Icons.lock, color: game.level >= canUnlockAt ? MagicColors.leaf : Colors.grey),
        ],
      ),
    );
  }
}

// Helper extension for formatting
extension GameStateFormatting on GameState {
  String _formatNumber(int n) {
    if (n >= 1000000) return '${(n/1000000).toStringAsFixed(1)}M';
    if (n >= 1000) return '${(n/1000).toStringAsFixed(1)}k';
    return n.toString();
  }
}

// Helper method for rarity color
extension RarityColor on GameState {
  Color rarityColor(Rarity r) {
    switch (r) {
      case Rarity.common: return MagicColors.common;
      case Rarity.rare: return MagicColors.rare;
      case Rarity.epic: return MagicColors.epic;
    }
  }
}
