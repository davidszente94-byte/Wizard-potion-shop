  // ==========================================
  // SAVE/LOAD
  // ==========================================
  Future<void> load() async {
    prefs = await SharedPreferences.getInstance();
    gold = prefs.getInt("gold") ?? 0;
    crystals = prefs.getInt("crystals") ?? 0;
    unlockedSlots = prefs.getInt("unlockedSlots") ?? 1;
    unlockedBrewSlots = prefs.getInt("unlockedBrewSlots") ?? 1;
    speedLevel = prefs.getInt("speedLevel") ?? 0;
    level = prefs.getInt("level") ?? 1;
    xp = prefs.getInt("xp") ?? 0;
    instantGrowTokens = prefs.getInt("instantGrowTokens") ?? 0;
    instantBrewTokens = prefs.getInt("instantBrewTokens") ?? 0;
    brewSpeed = 1.0 + speedLevel * 0.25;
    lastSaveTime = prefs.getInt("lastSaveTime") ?? DateTime.now().millisecondsSinceEpoch;
    doubleXpCharges = prefs.getInt("doubleXpCharges") ?? 0;
    doubleGoldCharges = prefs.getInt("doubleGoldCharges") ?? 0;

    for (int i = 0; i < plants.length; i++) {
      storage[i] = prefs.getInt("storage_$i") ?? 0;
    }
    for (int i = 0; i < seeds.length; i++) {
      seedStorage[i] = prefs.getInt("seeds_$i") ?? 0;
    }

    // Load garden slots
    for (int i = 0; i < maxGardenSlots; i++) {
      String? data = prefs.getString("garden_$i");
      if (data != null) {
        gardenSlots[i] = IdleGardenSlot.fromJson(jsonDecode(data));
      }
    } catch (e) {
    gardenSlots[i] = null; // Reset slot if data is corrupted
    }
    }

    // Load brew slots
    for (int i = 0; i < maxBrewSlots; i++) {
      String? data = prefs.getString("brew_$i");
      if (data != null) {
        brewSlots[i] = IdleBrewSlot.fromJson(jsonDecode(data));
      }
  } catch (e) {
  brewSlots[i] = null; // Reset slot if data is corrupted
  }
    }

    // Process offline progress (max 4 hours)
    processOfflineProgress();

    initShop();
    notifyListeners();
  }

  void processOfflineProgress() {
    final now = DateTime.now().millisecondsSinceEpoch;
    final offlineSeconds = ((now - lastSaveTime) ~/ 1000).clamp(0, maxIdleSeconds);

    if (offlineSeconds > 0) {
      // Simulate garden progress
      for (int i = 0; i < maxGardenSlots; i++) {
        final slot = gardenSlots[i];
        if (slot == null || !slot.isActive) continue;

        final seed = seeds[slot.seedId];
        final growTime = seed.growTime.inSeconds;
        int possibleCycles = offlineSeconds ~/ growTime;

        // Limit by gold
        if (seed.cost > 0) {
          int maxAffordable = gold ~/ seed.cost;
          possibleCycles = possibleCycles.clamp(0, maxAffordable);
        }

        // Cap at reasonable amount for offline
        possibleCycles = possibleCycles.clamp(0, maxIdleSeconds ~/ growTime);

        for (int c = 0; c < possibleCycles; c++) {
          if (seed.cost > 0) gold -= seed.cost;

          double roll = Random().nextDouble();
          double sum = 0;
          int resultPlant = seed.results.first.plantId;
          for (var r in seed.results) {
            sum += r.chance;
            if (roll <= sum) {
              resultPlant = r.plantId;
              break;
            }
          }
          storage[resultPlant]++;
          slot.cyclesCompleted++;
          gainXP(getPlantXp(resultPlant));
        }

        slot.startTime = now; // Reset for online progress
      }

      // Simulate brew progress
      for (int i = 0; i < maxBrewSlots; i++) {
        final slot = brewSlots[i];
        if (slot == null || !slot.isActive) continue;

        final recipe = getRecipeByKey(slot.recipeKey);
        if (recipe == null) continue;

        final brewTime = getPotionBrewTime(recipe).inSeconds;
        int possibleCycles = offlineSeconds ~/ brewTime;

        // Limit by materials
        List<int> materials = List<int>.from(recipe.ids);
        for (int plantId in materials.toSet()) {
          int count = materials.where((id) => id == plantId).length;
          int available = storage[plantId] ~/ count;
          if (available < possibleCycles) possibleCycles = available;
        }

        possibleCycles = possibleCycles.clamp(0, maxIdleSeconds ~/ brewTime);

        for (int c = 0; c < possibleCycles; c++) {
          for (int plantId in materials) {
            storage[plantId]--;
          }
          gold += calculatePotionSellPrice(recipe);
          slot.cyclesCompleted++;
          gainXP(getPotionXp(recipe.rarity));
        }

        slot.startTime = now;
      }
    }
  }

  Future<void> save() async {
    lastSaveTime = DateTime.now().millisecondsSinceEpoch;
    await prefs.setInt("gold", gold);
    await prefs.setInt("crystals", crystals);
    await prefs.setInt("unlockedSlots", unlockedSlots);
    await prefs.setInt("unlockedBrewSlots", unlockedBrewSlots);
    await prefs.setInt("speedLevel", speedLevel);
    await prefs.setInt("level", level);
    await prefs.setInt("xp", xp);
    await prefs.setInt("instantGrowTokens", instantGrowTokens);
    await prefs.setInt("instantBrewTokens", instantBrewTokens);
    await prefs.setInt("lastSaveTime", lastSaveTime);
    await prefs.setInt("doubleXpCharges", doubleXpCharges);
    await prefs.setInt("doubleGoldCharges", doubleGoldCharges);

    for (int i = 0; i < plants.length; i++) {
      await prefs.setInt("storage_$i", storage[i]);
    }
    for (int i = 0; i < seeds.length; i++) {
      await prefs.setInt("seeds_$i", seedStorage[i]);
    }

    for (int i = 0; i < maxGardenSlots; i++) {
      if (gardenSlots[i] != null) {
        await prefs.setString("garden_$i", jsonEncode(gardenSlots[i]!.toJson()));
      } else {
        await prefs.remove("garden_$i");
      }
    }

    for (int i = 0; i < maxBrewSlots; i++) {
      if (brewSlots[i] != null) {
        await prefs.setString("brew_$i", jsonEncode(brewSlots[i]!.toJson()));
      } else {
        await prefs.remove("brew_$i");
      }
    }
  }
