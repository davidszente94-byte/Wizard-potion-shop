        padding: const EdgeInsets.all(16),
        children: [
          const Center(
            child: Text(
              '📜 Ancient Recipe Book',
              style: TextStyle(color: MagicColors.gold, fontSize: 24, fontWeight: FontWeight.bold),
            ),
          ),
          const SizedBox(height: 8),
          Center(
            child: Text(
              'Unlock recipes by leveling up',
              style: TextStyle(color: MagicColors.textMuted.withOpacity(0.8)),
