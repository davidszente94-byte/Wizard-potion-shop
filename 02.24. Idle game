  Widget _buildGardenPlot(BuildContext context, int index) {
    if (index >= game.unlockedSlots) {
      int goldCost = game.getGardenSlotCost(index);
      int crystalCost = game.getGardenSlotCrystalCost(index);
      bool canAfford = goldCost > 0 ? game.gold >= goldCost : game.crystals >= crystalCost;

      return GestureDetector(
        onTap: canAfford ? () {
          game.unlockGardenSlot();
          _showUnlockDialog(context, 'Garden Slot ${index + 1}');
        } : null,
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            color: Colors.black26,
            borderRadius: BorderRadius.circular(16),
            border: Border.all(
              color: canAfford ? MagicColors.crystal.withOpacity(0.6) : Colors.grey.withOpacity(0.3),
              width: 2,
            ),
          ),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(Icons.lock_open, color: Colors.grey),
              const SizedBox(height: 4),
              if (goldCost > 0)
                Text(
                  '${game._formatNumber(goldCost)}g',
                  style: TextStyle(
                    color: canAfford ? MagicColors.gold : Colors.grey,
                    fontSize: 12,
                    fontWeight: FontWeight.bold,
                  ),
                )
              else if (crystalCost > 0)
                Row(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Text(
                      '$crystalCost',
                      style: TextStyle(
                        color: canAfford ? MagicColors.crystal : Colors.grey,
                        fontSize: 12,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                    const Icon(Icons.diamond, color: MagicColors.crystal, size: 12),
                  ],
                )
              else
                const Text('MAX', style: TextStyle(color: Colors.grey, fontSize: 10)),
            ],
          ),
        ),
      );
    }

    final slot = game.gardenSlots[index];
    if (slot == null) {
      return GestureDetector(
        onTap: () => _showSeedSelection(context, index),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            gradient: LinearGradient(
              colors: [
                MagicColors.earth.withOpacity(0.6),
                MagicColors.earthLight.withOpacity(0.4),
              ],
            ),
            borderRadius: BorderRadius.circular(16),
            border: Border.all(color: MagicColors.leaf.withOpacity(0.5)),
          ),
          child: const Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              Icon(Icons.add, color: MagicColors.leafLight),
              SizedBox(height: 4),
              Text('Plant', style: TextStyle(color: MagicColors.textMuted, fontSize: 10)),
            ],
          ),
        ),
      );
    }

    final seed = seeds[slot.seedId];
    final progress = game.getGardenSlotProgress(index);
    final isReady = progress >= 1;

    return GestureDetector(
      onTap: () => _showSlotStats(context, index),
      child: Container(
        width: 80,
        height: 100,
        decoration: BoxDecoration(
          gradient: LinearGradient(
            colors: [
              seed.color.withOpacity(0.4),
              seed.color.withOpacity(0.1),
            ],
          ),
          borderRadius: BorderRadius.circular(16),
          border: Border.all(color: seed.color.withOpacity(0.6), width: 2),
        ),
        child: Stack(
          children: [
            ClipRRect(
              borderRadius: BorderRadius.circular(16),
              child: LinearProgressIndicator(
                value: progress,
                backgroundColor: Colors.transparent,
                valueColor: AlwaysStoppedAnimation<Color>(seed.color.withOpacity(0.3)),
                minHeight: 100,
              ),
            ),
            Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Text(seed.icon, style: const TextStyle(fontSize: 28)),
                  const SizedBox(height: 4),
                  Text(
                    seed.name,
                    style: const TextStyle(color: MagicColors.textLight, fontSize: 9),
                    textAlign: TextAlign.center,
                  ),
                  if (!isReady)
                    Text(
                      game.getGardenSlotTimeLeft(index),
                      style: const TextStyle(color: MagicColors.textMuted, fontSize: 10),
                    ),
                ],
              ),
            ),
            Positioned(
              top: 4,
              right: 4,
              child: GestureDetector(
                onTap: () => game.stopIdleGarden(index),
                child: Container(
                  padding: const EdgeInsets.all(2),
                  decoration: BoxDecoration(
                    color: Colors.red.withOpacity(0.3),
                    shape: BoxShape.circle,
                  ),
                  child: const Icon(Icons.close, color: Colors.red, size: 14),
                ),
              ),
            ),
            if (game.instantGrowTokens > 0)
              Positioned(
                top: 4,
                left: 4,
                child: GestureDetector(
                  onTap: () => game.useInstantGrow(index),
                  child: Container(
                    padding: const EdgeInsets.symmetric(horizontal: 4, vertical: 2),
                    decoration: BoxDecoration(
                      color: Colors.yellow.withOpacity(0.3),
                      borderRadius: BorderRadius.circular(8),
                    ),
                    child: Row(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        const Icon(Icons.bolt, color: Colors.yellow, size: 10),
                        Text('${game.instantGrowTokens}', style: const TextStyle(color: Colors.yellow, fontSize: 8)),
                      ],
                    ),
                  ),
                ),
              ),
          ],
        ),
      ),
    );
  }

  void _showSeedSelection(BuildContext context, int slotIndex) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Seed for Idle Growth', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          child: ListView(
            shrinkWrap: true,
            children: seeds.map((s) {
              final canAfford = s.cost == 0 || game.gold >= s.cost;
              return ListTile(
                leading: Text(s.icon, style: const TextStyle(fontSize: 24)),
                title: Text(s.name, style: TextStyle(color: canAfford ? MagicColors.textLight : Colors.grey)),
                subtitle: Text(
                  s.cost == 0 ? 'Free' : '${s.cost}g per cycle',
                  style: TextStyle(color: canAfford ? MagicColors.textMuted : Colors.red),
                ),
                trailing: Text(
                  formatDuration(s.growTime),
                  style: TextStyle(color: s.color, fontWeight: FontWeight.bold),
                ),
                onTap: canAfford ? () {
                  game.startIdleGarden(slotIndex, s.id);
                  Navigator.pop(ctx);
                } : null,
              );
            }).toList(),
          ),
        ),
      ),
    );
  }

  void _showSlotStats(BuildContext context, int index) {
    final slot = game.gardenSlots[index];
    if (slot == null) return;
    final seed = seeds[slot.seedId];
    final plantsPerHour = game.getGardenPlantsPerHour(index);

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('${seed.name} Production', style: const TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('Cycles completed: ${slot.cyclesCompleted}', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 8),
            Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: seed.color.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Column(
                children: [
                  const Text('Production Rate', style: TextStyle(color: MagicColors.textMuted, fontSize: 12)),
                  Text(
                    '${plantsPerHour.toStringAsFixed(1)} plants/hour',
                    style: TextStyle(
                      color: seed.color,
                      fontSize: 20,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 8),
            Text(
              'Cost: ${seed.cost}g per cycle',
              style: TextStyle(color: seed.cost > 0 ? MagicColors.gold : MagicColors.leaf),
            ),
            Text(
              'Time: ${formatDuration(seed.growTime)} per cycle',
              style: const TextStyle(color: MagicColors.textMuted),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }

  void _showUnlockDialog(BuildContext context, String name) {
    showDialog(
      context: context,
      builder: (_) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('🌱 $name Unlocked!', style: const TextStyle(color: MagicColors.leaf)),
        content: Text('$name is now available!', style: const TextStyle(color: MagicColors.textLight)),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Great!'),
          ),
        ],
      ),
    );
  }

  Widget _buildSeedInventory() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: MagicColors.surface.withOpacity(0.6),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: MagicColors.leaf.withOpacity(0.3)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Row(
            children: [
              Icon(Icons.grass, color: MagicColors.leaf),
              SizedBox(width: 8),
              Text(
                'Seed Storage',
                style: TextStyle(color: MagicColors.textLight, fontWeight: FontWeight.bold),
              ),
            ],
          ),
          const SizedBox(height: 12),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: seeds.map((seed) {
              final count = game.seedStorage[seed.id];
              return Container(
                padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
                decoration: BoxDecoration(
                  color: seed.color.withOpacity(0.2),
                  borderRadius: BorderRadius.circular(16),
                  border: Border.all(color: seed.color.withOpacity(0.5)),
                ),
                child: Row(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Text(seed.icon),
                    const SizedBox(width: 6),
                    Text(seed.name, style: TextStyle(color: seed.color, fontSize: 12)),
                    if (count > 0) ...[
                      const SizedBox(width: 6),
                      Container(
                        padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                        decoration: BoxDecoration(
                          color: Colors.black26,
                          borderRadius: BorderRadius.circular(10),
                        ),
                        child: Text('x$count', style: const TextStyle(color: MagicColors.textLight, fontSize: 10)),
                      ),
                    ],
