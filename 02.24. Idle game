  int getPlantXp(int plantId) => plants[plantId].xpValue;

  int getPotionXp(Rarity rarity) {
    switch (rarity) {
      case Rarity.common: return 40;
      case Rarity.rare: return 120;
      case Rarity.epic: return 400;
    }
  }

  int neededExp(int lvl) => (100 + (pow(lvl, 1.8) * 80)).round();

  double xpProgress() => (xp / neededExp(level)).clamp(0.0, 1.0);

  bool gainXP(int amount) {
    xp += amount;
    bool leveled = false;
    int levelsGained = 0;
    while (xp >= neededExp(level)) {
      xp -= neededExp(level);
      level++;
      levelsGained++;
      leveled = true;
    }
    if (levelsGained > 0) {
      crystals += levelsGained;
    }
    if (leveled) notifyListeners();
    return leveled;
  }

