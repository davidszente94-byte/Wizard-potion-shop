class IdleGardenSlot {
  int seedId;
  int startTime;
  int cyclesCompleted;
  bool isActive;

  IdleGardenSlot({
    required this.seedId,
    required this.startTime,
    this.cyclesCompleted = 0,
    this.isActive = true,
  });

  Map<String, dynamic> toJson() {
    return {
      "seedId": seedId,
      "start": startTime,
      "cycles": cyclesCompleted,
      "active": isActive,
    };
  }

  factory IdleGardenSlot.fromJson(Map<String, dynamic> json) {
    return IdleGardenSlot(
      seedId: json["seedId"],
      startTime: json["start"],
      cyclesCompleted: json["cycles"] ?? 0,
      isActive: json["active"] ?? true,
    );
  }
}

