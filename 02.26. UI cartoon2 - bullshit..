              ),
              Positioned(
                bottom: 0,
                child: Container(
                  padding: EdgeInsets.symmetric(horizontal: width * 0.1, vertical: 2),
                  decoration: BoxDecoration(
                    color: Colors.black.withOpacity(0.7),
                    borderRadius: BorderRadius.circular(4),
                  ),
                  child: Text(
                    goldCost > 0 ? '$goldCost🪙' : '$crystalCost💎',
                    style: TextStyle(
                      color: canAfford ? MagicColors.gold : Colors.grey,
                      fontSize: width * 0.15,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ),
              ),
            ],
          ),
        ),
      );
    }

    final slot = widget.game.brewSlots[index];

    if (slot == null) {
      return Positioned(
        left: left,
        top: top,
        width: width,
        height: height,
        child: GestureDetector(
          onTap: () => _showPotionSelection(context, index),
          child: Stack(
            alignment: Alignment.center,
            children: [
              Image.asset(
                'assets/images/potion.png',
                fit: BoxFit.contain,
