                child: Icon(Icons.add, color: Colors.white, size: width * 0.4),
              ),
            ],
          ),
        ),
      );
    }

    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return SizedBox(width: width, height: height);

    final progress = widget.game.getBrewSlotProgress(index);

    return Positioned(
      left: left,
      top: top,
      width: width,
      height: height,
      child: GestureDetector(
        onTap: () => _showBrewStats(context, index),
        child: Stack(
          alignment: Alignment.center,
          children: [
            Image.asset(
              'assets/images/potion.png',
              fit: BoxFit.contain,
            ),
            ClipRRect(
              borderRadius: BorderRadius.circular(width * 0.3),
              child: Align(
                alignment: Alignment.bottomCenter,
                child: Container(
                  width: width * 0.7,
                  height: height * 0.6 * progress,
                  margin: EdgeInsets.only(bottom: height * 0.15),
                  decoration: BoxDecoration(
                    color: rarityColor(recipe.rarity).withOpacity(0.7),
