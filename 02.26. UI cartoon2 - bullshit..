class PotionConfig {
  static Size _screenSize = Size.zero;

  static void init(BuildContext context) {
    _screenSize = MediaQuery.of(context).size;
  }

  static double get screenWidth => _screenSize.width;
  static double get screenHeight => _screenSize.height;
  static double w(double percent) => screenWidth * (percent / 100);
  static double h(double percent) => screenHeight * (percent / 100);

  // TABLE CONFIGURATION
  // Define tables by their screen percentage position and size
  static final Map<String, Map<String, double>> tables = {
    'table1': {
      'left': 8,   // 8% from left of screen
      'top': 32,   // 32% from top of screen
      'width': 38, // 38% of screen width
      'height': 15 // 15% of screen height
    },
    'table2': {
      'left': 54,
      'top': 32,
      'width': 38,
      'height': 15
    },
    'table3': {
      'left': 12,
      'top': 55,
      'width': 35,
      'height': 13
    },
    'table4': {
      'left': 53,
      'top': 55,
      'width': 35,
      'height': 13
    },
  };

  // ==========================================
  // POTION POSITIONS - PERCENTAGE OF TABLE
  // Format: [left% of table width, top% of table height]
  //
  // 0 = left/top edge of table
  // 50 = center of table
  // 100 = right/bottom edge of table
  // ==========================================

  static final Map<int, List<double>> potionOffsets = {
    // TABLE 1 (slots 0,1,2) - 3 potions spread across
    0: [15.0, 20.0],   // 15% from table left, 20% from table top
    1: [50.0, 20.0],   // Center horizontally, 20% from top
    2: [85.0, 20.0],   // 85% from table left (near right edge)

    // TABLE 2 (slots 3,4,5)
    3: [15.0, 20.0],
    4: [50.0, 20.0],
    5: [85.0, 20.0],

    // TABLE 3 (slots 6,7) - 2 potions, more spacing
    6: [25.0, 25.0],
    7: [75.0, 25.0],

    // TABLE 4 (slots 8,9)
    8: [25.0, 25.0],
    9: [75.0, 25.0],
  };

  // Get which table a slot belongs to
  static String getTableForSlot(int slotIndex) {
    if (slotIndex < 3) return 'table1';
    if (slotIndex < 6) return 'table2';
    if (slotIndex < 8) return 'table3';
    return 'table4';
  }

  // Get absolute screen position for a potion
  static Offset getAbsolutePosition(int slotIndex) {
    final tableName = getTableForSlot(slotIndex);
    final table = tables[tableName]!;
    final offset = potionOffsets[slotIndex] ?? [50.0, 50.0];

    // Convert table percentages to pixels
    final tableLeftPx = w(table['left']!);
    final tableTopPx = h(table['top']!);
    final tableWidthPx = w(table['width']!);
    final tableHeightPx = h(table['height']!);

    // Calculate potion position: table edge + (table size * percentage)
    final potionLeft = tableLeftPx + (tableWidthPx * offset[0] / 100);
    final potionTop = tableTopPx + (tableHeightPx * offset[1] / 100);

    return Offset(potionLeft, potionTop);
  }

  // Get position RELATIVE to table (for use inside Positioned within table Stack)
  static Offset getRelativePosition(int slotIndex) {
    final tableName = getTableForSlot(slotIndex);
    final table = tables[tableName]!;
    final offset = potionOffsets[slotIndex] ?? [50.0, 50.0];

    final tableWidthPx = w(table['width']!);
    final tableHeightPx = h(table['height']!);

    // Position relative to table's top-left corner
    final relativeLeft = tableWidthPx * offset[0] / 100;
    final relativeTop = tableHeightPx * offset[1] / 100;

    return Offset(relativeLeft, relativeTop);
  }

  // Get potion size (relative to table or screen)
  static double get potionWidth => w(60);
  static double get potionHeight => h(8);

  // Size relative to specific table
  static double getPotionWidthForTable(int slotIndex) {
    final tableName = getTableForSlot(slotIndex);
    final table = tables[tableName]!;
    return w(table['width']!) * 0.25; // 25% of table width
  }

  static double getPotionHeightForTable(int slotIndex) {
    final tableName = getTableForSlot(slotIndex);
    final table = tables[tableName]!;
    return h(table['height']!) * 0.70; // 70% of table height
  }
}

