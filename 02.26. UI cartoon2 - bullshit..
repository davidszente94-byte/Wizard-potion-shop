                    recipe.rarity.name.toUpperCase(),
                    style: TextStyle(color: rarityColor(recipe.rarity), fontSize: 9, fontWeight: FontWeight.bold),
                  ),
                ),
                onTap: hasMaterials ? () {
                  widget.game.startIdleBrew(slotIndex, recipe.key);
                  Navigator.pop(ctx);
                } : null,
              );
            },
          ),
        ),
      ),
    );
