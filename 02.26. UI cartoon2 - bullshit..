class ShopScreen extends StatelessWidget {
  final GameState game;
  final Function(int) onNavigate;

  const ShopScreen({
    super.key,
    required this.game,
    required this.onNavigate,
  });

  @override
  Widget build(BuildContext context) {
    return Stack(
      fit: StackFit.expand,
      children: [
        // Background - Open book
        Image.asset(
          'assets/images/book_open.png',
          fit: BoxFit.cover,
        ),

        // Content overlay on the book pages
        SafeArea(
          child: Column(
            children: [
              // Back button
              Align(
                alignment: Alignment.topLeft,
                child: Padding(
                  padding: const EdgeInsets.all(16),
                  child: GestureDetector(
                    onTap: () => onNavigate(0),
                    child: Container(
                      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                      decoration: BoxDecoration(
                        color: MagicColors.wood.withOpacity(0.8),
                        borderRadius: BorderRadius.circular(20),
                        border: Border.all(color: MagicColors.gold.withOpacity(0.5)),
                      ),
                      child: const Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Icon(Icons.arrow_back, color: Colors.white, size: 20),
                          SizedBox(width: 8),
                          Text(
                            'Back to Lab',
                            style: TextStyle(
                              color: Colors.white,
                              fontWeight: FontWeight.bold,
                              fontSize: 14,
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
                ),
              ),

              // Title
              const Text(
                '🏪 Magic Shop',
                style: TextStyle(
                  color: Color(0xFF5D4037),
                  fontSize: 28,
                  fontWeight: FontWeight.bold,
                  fontFamily: 'Serif',
                  shadows: [
                    Shadow(
                      color: Colors.white54,
                      blurRadius: 4,
                      offset: Offset(1, 1),
                    ),
                  ],
                ),
              ),

              const SizedBox(height: 8),

              const Text(
                'Daily items reset at midnight',
                style: TextStyle(
                  color: Color(0xFF8D6E63),
                  fontSize: 12,
                  fontStyle: FontStyle.italic,
                ),
              ),

              const SizedBox(height: 16),

              // Shop items list
              Expanded(
                child: Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 40),
                  child: ListView(
                    children: [
                      _buildShopSection('⚡ Boost Tokens (Daily)', game.shopItems.where((i) => i.isDailyLimited).toList(), context),
                      const SizedBox(height: 20),
                      _buildShopSection('💰 Gold Pouches', game.shopItems.where((i) => i.id.contains('gold_pouch')).toList(), context),
                      const SizedBox(height: 20),
                      _buildShopSection('🌱 Plants', game.shopItems.where((i) => i.plantId != null).toList(), context),
                    ],
                  ),
                ),
              ),
            ],
          ),
        ),
      ],
    );
  }

  Widget _buildShopSection(String title, List<ShopItem> items, BuildContext context) {
    if (items.isEmpty) return const SizedBox.shrink();

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          title,
          style: const TextStyle(
            color: Color(0xFF5D4037),
            fontSize: 18,
            fontWeight: FontWeight.bold,
            fontFamily: 'Serif',
          ),
        ),
        const SizedBox(height: 8),
        ...items.map((item) => _buildShopCard(item, context)),
      ],
    );
  }

  Widget _buildShopCard(ShopItem item, BuildContext context) {
    final canAfford = item.currency == ShopCurrency.gold
        ? game.gold >= item.price
        : game.crystals >= item.price;

    final isDailyLimited = item.isDailyLimited;
    final canBuyDaily = isDailyLimited ? game.canBuyDailyItem(item.id) : true;
    final bool actuallyCanBuy = canAfford && canBuyDaily;

    return Container(
      margin: const EdgeInsets.only(bottom: 8),
      padding: const EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: const Color(0xFFF5F5DC).withOpacity(0.7),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: actuallyCanBuy ? const Color(0xFF8D6E63) : Colors.grey,
          width: 1,
        ),
      ),
      child: Row(
        children: [
          Container(
            padding: const EdgeInsets.all(8),
            decoration: BoxDecoration(
              color: item.color.withOpacity(0.2),
              shape: BoxShape.circle,
            ),
            child: Icon(item.icon, color: item.color, size: 24),
          ),
          const SizedBox(width: 12),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  item.name,
                  style: const TextStyle(
                    color: Color(0xFF5D4037),
                    fontWeight: FontWeight.bold,
                    fontSize: 14,
                  ),
                ),
                Text(
                  item.description,
                  style: const TextStyle(
                    color: Color(0xFF8D6E63),
                    fontSize: 11,
                  ),
                ),
                if (isDailyLimited && !canBuyDaily)
                  const Text(
                    'Daily limit reached!',
                    style: TextStyle(color: Colors.red, fontSize: 10, fontWeight: FontWeight.bold),
                  ),
              ],
            ),
          ),
          ElevatedButton(
            onPressed: actuallyCanBuy ? () {
              final rewards = game.buyShopItemWithPopup(item);
              showDialog(
                context: context,
                builder: (_) => AlertDialog(
                  backgroundColor: const Color(0xFFF5F5DC),
                  title: Text(
                    rewards.first.contains('limit') ? 'Limit Reached' : 'Acquired!',
                    style: TextStyle(
                      color: rewards.first.contains('limit') ? Colors.red : const Color(0xFF5D4037),
                    ),
                  ),
                  content: Text(rewards.first, style: const TextStyle(color: Color(0xFF5D4037))),
                  actions: [
                    TextButton(
                      onPressed: () => Navigator.pop(context),
                      child: const Text('OK', style: TextStyle(color: Color(0xFF5D4037))),
                    ),
                  ],
                ),
              );
            } : null,
            style: ElevatedButton.styleFrom(
              backgroundColor: item.currency == ShopCurrency.gold
                  ? MagicColors.gold.withOpacity(0.8)
                  : MagicColors.crystal.withOpacity(0.8),
              foregroundColor: Colors.white,
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
            ),
            child: Row(
              mainAxisSize: MainAxisSize.min,
              children: [
                if (item.currency == ShopCurrency.crystal)
                  const Icon(Icons.diamond, size: 14),
                Text('${item.price}'),
              ],
            ),
          ),
        ],
      ),
    );
  }
}

// ==========================================
// RECIPE BOOK SCREEN - Premium Design
// ==========================================
class RecipeBookScreen extends StatefulWidget {
  final GameState game;
  final Function(int) onNavigate;

  const RecipeBookScreen({
    super.key,
    required this.game,
    required this.onNavigate,
  });

  @override
  State<RecipeBookScreen> createState() => _RecipeBookScreenState();
}

class _RecipeBookScreenState extends State<RecipeBookScreen> {
  int currentPage = 0;
  final int recipesPerPage = 4;

  @override
  Widget build(BuildContext context) {
    final totalPages = (allRecipes.length / recipesPerPage).ceil();
    final startIndex = currentPage * recipesPerPage;
    final endIndex = (startIndex + recipesPerPage).clamp(0, allRecipes.length);
    final pageRecipes = allRecipes.sublist(startIndex, endIndex);

    return Stack(
      fit: StackFit.expand,
      children: [
        // Background - Open book
        Image.asset(
          'assets/images/book_open.png',
          fit: BoxFit.cover,
        ),

        // Content
        SafeArea(
          child: Column(
            children: [
              // Back button
              Align(
                alignment: Alignment.topLeft,
                child: Padding(
                  padding: const EdgeInsets.all(16),
                  child: GestureDetector(
                    onTap: () => widget.onNavigate(0),
                    child: Container(
                      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                      decoration: BoxDecoration(
                        color: MagicColors.wood.withOpacity(0.8),
                        borderRadius: BorderRadius.circular(20),
                        border: Border.all(color: MagicColors.gold.withOpacity(0.5)),
                      ),
                      child: const Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Icon(Icons.arrow_back, color: Colors.white, size: 20),
                          SizedBox(width: 8),
                          Text(
                            'Back to Lab',
                            style: TextStyle(
                              color: Colors.white,
                              fontWeight: FontWeight.bold,
                              fontSize: 14,
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
                ),
              ),

              // Title
              const Text(
                '📜 Recipe Book',
                style: TextStyle(
                  color: Color(0xFF5D4037),
                  fontSize: 28,
                  fontWeight: FontWeight.bold,
                  fontFamily: 'Serif',
                  shadows: [
                    Shadow(
                      color: Colors.white54,
                      blurRadius: 4,
                      offset: Offset(1, 1),
                    ),
                  ],
                ),
              ),

              const SizedBox(height: 8),

              Text(
                'Page ${currentPage + 1} of $totalPages',
                style: const TextStyle(
                  color: Color(0xFF8D6E63),
                  fontSize: 14,
                  fontStyle: FontStyle.italic,
                ),
              ),

              const SizedBox(height: 16),

              // Recipes list
              Expanded(
                child: Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 40),
                  child: ListView(
                    children: pageRecipes.map((recipe) => _buildRecipeCard(recipe)).toList(),
                  ),
                ),
              ),

              // Navigation buttons
              Padding(
                padding: const EdgeInsets.all(16),
                child: Row(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    if (currentPage > 0)
                      ElevatedButton.icon(
                        onPressed: () => setState(() => currentPage--),
                        icon: const Icon(Icons.arrow_back),
                        label: const Text('Previous'),
                        style: ElevatedButton.styleFrom(
                          backgroundColor: const Color(0xFF8D6E63),
                          foregroundColor: Colors.white,
                        ),
                      ),
                    const SizedBox(width: 20),
                    if (currentPage < totalPages - 1)
                      ElevatedButton.icon(
                        onPressed: () => setState(() => currentPage++),
                        icon: const Icon(Icons.arrow_forward),
                        label: const Text('Next'),
                        style: ElevatedButton.styleFrom(
                          backgroundColor: const Color(0xFF8D6E63),
                          foregroundColor: Colors.white,
                        ),
                      ),
                  ],
                ),
              ),
            ],
          ),
        ),
      ],
    );
  }

  Widget _buildRecipeCard(Recipe recipe) {
    final isUnlocked = widget.game.isRecipeUnlocked(recipe.key);
    final color = isUnlocked ? rarityColor(recipe.rarity) : Colors.grey;

    return Container(
      margin: const EdgeInsets.only(bottom: 12),
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: const Color(0xFFF5F5DC).withOpacity(0.7),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: isUnlocked ? color : Colors.grey,
          width: 1,
        ),
      ),
      child: Row(
        children: [
          Container(
            width: 50,
            height: 50,
            decoration: BoxDecoration(
              color: isUnlocked ? color.withOpacity(0.2) : Colors.grey.withOpacity(0.1),
              shape: BoxShape.circle,
            ),
            child: Center(
              child: Text(
                isUnlocked ? recipe.icon : '🔒',
                style: const TextStyle(fontSize: 24),
              ),
            ),
          ),
          const SizedBox(width: 16),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  isUnlocked ? recipe.name : '???',
                  style: TextStyle(
                    color: isUnlocked ? const Color(0xFF5D4037) : Colors.grey,
                    fontWeight: FontWeight.bold,
                    fontSize: 16,
                    fontFamily: 'Serif',
                  ),
                ),
                const SizedBox(height: 4),
                if (isUnlocked) ...[
                  Row(
                    children: [
                      Container(
                        margin: const EdgeInsets.only(right: 4),
                        padding: const EdgeInsets.all(4),
                        decoration: BoxDecoration(
                          color: plants[recipe.plantTier].color.withOpacity(0.3),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: Text('${plants[recipe.plantTier].icon} x3'),
                      ),
                      Text(
                        plants[recipe.plantTier].name,
                        style: TextStyle(color: plants[recipe.plantTier].color, fontSize: 12),
                      ),
                    ],
                  ),
                  const SizedBox(height: 4),
                  Row(
                    children: [
                      Container(
                        padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                        decoration: BoxDecoration(
                          color: color.withOpacity(0.2),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: Text(
                          recipe.rarity.name.toUpperCase(),
                          style: TextStyle(color: color, fontSize: 10, fontWeight: FontWeight.bold),
                        ),
                      ),
                      const SizedBox(width: 8),
                      Text(
                        '${recipe.sellPrice}g • ${recipe.xpValue} XP',
                        style: const TextStyle(color: Color(0xFF8D6E63), fontSize: 11),
                      ),
                    ],
                  ),
                ] else
                  Text(
                    'Unlocks at Level ${recipe.unlockLevel}',
                    style: TextStyle(
                      color: widget.game.level >= recipe.unlockLevel ? MagicColors.leaf : Colors.grey,
                      fontSize: 12,
                    ),
                  ),
              ],
            ),
          ),
          if (isUnlocked)
            const Icon(Icons.check_circle, color: Colors.green)
          else
            Icon(Icons.lock, color: widget.game.level >= recipe.unlockLevel ? MagicColors.leaf : Colors.grey),
        ],
      ),
    );
  }
}

Color rarityColor(Rarity r) {
  switch (r) {
    case Rarity.common: return MagicColors.common;
    case Rarity.rare: return MagicColors.rare;
    case Rarity.epic: return MagicColors.epic;
  }
}
