class TableConfig {
  // Get screen size - call this in build method
  static Size _screenSize = Size.zero;

  static void init(BuildContext context) {
    _screenSize = MediaQuery.of(context).size;
  }

  static double get screenWidth => _screenSize.width;
  static double get screenHeight => _screenSize.height;

  // Helper to convert percentage (0-100) to pixels
  static double w(double percent) => screenWidth * (percent / 100);
  static double h(double percent) => screenHeight * (percent / 100);

  // TABLE 1 - Top Left (slots 0,1,2)
  // Position: 10% from left, 35% from top
  static double get table1Left => w(-3);
  static double get table1Top => h(43);
  static double get table1Width => w(52);
  static double get table1Height => h(50);

  // TABLE 2 - Top Right (slots 3,4,5)
  static double get table2Left => w(38);
  static double get table2Top => h(38);
  static double get table2Width => w(52);
  static double get table2Height => h(50);

  // TABLE 3 - Bottom Left (slots 6,7)
  static double get table3Left => w(-2);
  static double get table3Top => h(59);
  static double get table3Width => w(58);
  static double get table3Height => h(52);

  // TABLE 4 - Bottom Right (slots 8,9 + book)
  static double get table4Left => w(45);
  static double get table4Top => h(50);
  static double get table4Width => w(60);
  static double get table4Height => h(55);

  // Potions scale with table size
  static double get potionWidth => w(68);
  static double get potionHeight => h(10);

  // Book
  static double get bookRight => w(2);
  static double get bookTop => h(1);
  static double get bookWidth => w(8);
  static double get bookHeight => h(6);

  // Buttons
  static double get speedButtonTop => h(12);
  static double get doorLeft => w(5);
  static double get doorBottom => h(8);
  static double get doorWidth => w(18);
  static double get doorHeight => h(10);
}

