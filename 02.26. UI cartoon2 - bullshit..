          children: [
            Text('Current: Level ${game.growSpeedLevel}', style: const TextStyle(color: MagicColors.textLight)),
            Text('Next: Level ${game.growSpeedLevel + 1}', style: const TextStyle(color: MagicColors.textLight)),
            const SizedBox(height: 16),
            Text(
              'Cost: $cost Gold',
              style: TextStyle(
                color: game.gold >= cost ? MagicColors.gold : Colors.red,
                fontSize: 18,
                fontWeight: FontWeight.bold,
              ),
            ),
          ],
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(ctx), child: const Text('Cancel')),
          ElevatedButton(
            onPressed: game.gold >= cost ? () {
              game.upgradeGrowSpeed();
              Navigator.pop(ctx);
            } : null,
            child: const Text('Upgrade'),
          ),
        ],
      ),
    );
  }

  void _showUnlockSlotDialog(BuildContext context, int index, int goldCost, int crystalCost) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('Unlock Garden Slot ${index + 1}', style: const TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('Choose payment method:', style: TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 16),
            if (goldCost > 0)
              ListTile(
                leading: const Icon(Icons.monetization_on, color: MagicColors.gold),
                title: Text('$goldCost Gold', style: const TextStyle(color: MagicColors.textLight)),
                trailing: game.gold >= goldCost
                    ? ElevatedButton(
                  onPressed: () {
                    game.unlockGardenSlotWithGold();
                    Navigator.pop(ctx);
                  },
                  child: const Text('Buy'),
                )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
            if (crystalCost > 0)
              ListTile(
                leading: const Icon(Icons.diamond, color: MagicColors.crystal),
                title: Text('$crystalCost Crystals', style: const TextStyle(color: MagicColors.textLight)),
                trailing: game.crystals >= crystalCost
                    ? ElevatedButton(
                  onPressed: () {
                    game.unlockGardenSlotWithCrystals();
                    Navigator.pop(ctx);
                  },
                  child: const Text('Buy'),
                )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
          ],
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(ctx), child: const Text('Cancel')),
        ],
      ),
    );
  }

  void _showSeedSelection(BuildContext context, int slotIndex) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Seed', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          child: ListView(
            shrinkWrap: true,
            children: seeds.map((s) {
              final unlocked = game.isSeedUnlocked(s.id);
              final canAfford = s.cost == 0 || game.gold >= s.cost;
              final growTime = game.getGrowTime(s.plantId);

              if (!unlocked) {
                return ListTile(
                  leading: const Icon(Icons.lock, color: Colors.grey),
                  title: Text(s.name, style: const TextStyle(color: Colors.grey)),
                  subtitle: Text('Unlocks at Level ${s.unlockLevel}', style: const TextStyle(color: Colors.grey)),
                );
              }

              return ListTile(
                leading: Text(s.icon, style: const TextStyle(fontSize: 24)),
                title: Text(s.name, style: TextStyle(color: canAfford ? MagicColors.textLight : Colors.grey)),
                subtitle: Text(
                  s.cost == 0 ? 'Free • ${plants[s.plantId].xpValue} XP' : '${s.cost}g/cycle • ${plants[s.plantId].xpValue} XP',
                  style: TextStyle(color: canAfford ? MagicColors.textMuted : Colors.red),
                ),
                trailing: Text(
                  formatDuration(growTime),
                  style: TextStyle(color: s.color, fontWeight: FontWeight.bold),
                ),
                onTap: canAfford ? () {
                  game.startIdleGarden(slotIndex, s.id);
                  Navigator.pop(ctx);
                } : null,
              );
            }).toList(),
          ),
        ),
      ),
    );
  }

  void _showSlotStats(BuildContext context, int index) {
    final slot = game.gardenSlots[index];
    if (slot == null) return;
    final seed = seeds[slot.seedId];
    final plantsPerHour = game.getGardenPlantsPerHour(index);

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text(seed.name, style: TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('Cycles: ${slot.cyclesCompleted}', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 8),
            Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: seed.color.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Column(
                children: [
                  const Text('Production', style: TextStyle(color: MagicColors.textMuted, fontSize: 12)),
                  Text(
                    '${plantsPerHour.toStringAsFixed(1)}/hour',
                    style: TextStyle(color: seed.color, fontSize: 20, fontWeight: FontWeight.bold),
                  ),
                ],
              ),
            ),
          ],
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(ctx), child: const Text('Close')),
        ],
      ),
    );
  }
}

