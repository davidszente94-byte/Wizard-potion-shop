  void _showBrewStats(BuildContext context, int index) {
    final slot = widget.game.brewSlots[index];
    if (slot == null) return;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return;
    final goldPerHour = widget.game.getBrewGoldPerHour(index);

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text(recipe.name, style: TextStyle(color: rarityColor(recipe.rarity))),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('Cycles: ${slot.cyclesCompleted}', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 12),
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: MagicColors.gold.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: MagicColors.gold),
              ),
              child: Column(
                children: [
                  const Text('Gold/Hour', style: TextStyle(color: MagicColors.textMuted, fontSize: 12)),
                  Text(
                    '${_formatNumber(goldPerHour.round())}',
                    style: const TextStyle(color: MagicColors.gold, fontSize: 24, fontWeight: FontWeight.bold),
                  ),
                ],
              ),
            ),
          ],
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(ctx), child: const Text('Close')),
        ],
      ),
    );
  }

  String _formatNumber(int n) {
    if (n >= 1000000) return '${(n/1000000).toStringAsFixed(1)}M';
    if (n >= 1000) return '${(n/1000).toStringAsFixed(1)}k';
    return n.toString();
  }
}


// ==========================================
// GARDEN SCREEN - Fully Responsive
// ==========================================

class GardenScreen extends StatefulWidget {
  final GameState game;
  final Function(int) onNavigate;
  final Function(List<String>)? onLevelUp;

  const GardenScreen({
    super.key,
    required this.game,
    required this.onNavigate,
    this.onLevelUp,
  });

  @override
  State<GardenScreen> createState() => _GardenScreenState();
}

class _GardenScreenState extends State<GardenScreen> {
  // Mutable positions for runtime tuning
  late Map<int, List<double>> _slotPositions;
  bool _showDebugger = false;
  int _selectedSlot = 0;

  @override
  void initState() {
    super.initState();
    _slotPositions = Map.fromEntries(
      GardenLayoutConfig.slotPositions.entries.map(
            (e) => MapEntry(e.key, List<double>.from(e.value)),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return LayoutBuilder(
      builder: (context, constraints) {
        final maxWidth = constraints.maxWidth;
        final maxHeight = constraints.maxHeight;

        return Stack(
          fit: StackFit.expand,
          children: [
            // Background - Garden house
            Image.asset(
              'assets/images/garden_house.png',
              fit: BoxFit.cover,
            ),

            // Speed upgrade button
            if (widget.game.growSpeedLevel < 10)
              _buildSpeedButton(constraints),

            // Garden slots
            ...List.generate(10, (index) => _buildGardenSlot(constraints, index)),

            // Door to Lab
            _buildLabDoor(constraints),

            // Debug toggle
            _buildDebugToggle(constraints),

            // Debug overlays
            if (_showDebugger) ...[
              _buildDebugOverlay(constraints),
              _buildPercentageDebugger(constraints),
            ],
          ],
        );
      },
    );
  }

  Widget _buildSpeedButton(BoxConstraints constraints) {
    final config = GardenLayoutConfig.speedButton;
    final left = constraints.maxWidth * config['left']!;
    final top = constraints.maxHeight * config['top']!;

    return Positioned(
      left: left,
      top: top,
      child: ElevatedButton.icon(
        onPressed: () => _showSpeedUpgradeDialog(context),
        icon: const Icon(Icons.speed, size: 18),
        label: Text('Upgrade Speed (Lvl ${widget.game.growSpeedLevel + 1})'),
        style: ElevatedButton.styleFrom(
          backgroundColor: MagicColors.leaf.withOpacity(0.8),
          foregroundColor: Colors.white,
          side: const BorderSide(color: Colors.white70),
          shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
        ),
      ),
    );
  }

  Widget _buildGardenSlot(BoxConstraints constraints, int index) {
    final maxWidth = constraints.maxWidth;
    final maxHeight = constraints.maxHeight;

    final pos = _slotPositions[index]!;
    final left = maxWidth * pos[0];
    final top = maxHeight * pos[1];
    final size = maxWidth * GardenLayoutConfig.slotSizePercent;

    // Center the slot on the position point
    final centeredLeft = left - (size / 2);
    final centeredTop = top - (size / 2);

    if (index >= widget.game.unlockedSlots) {
      return _buildLockedSlot(context, index, centeredLeft, centeredTop, size);
    }

    final slot = widget.game.gardenSlots[index];
    if (slot == null) {
      return Positioned(
        left: centeredLeft,
        top: centeredTop,
        width: size,
        height: size,
        child: GestureDetector(
          onTap: () => _showSeedSelection(context, index),
          child: Container(
            decoration: BoxDecoration(
              color: MagicColors.earth.withOpacity(0.5),
              shape: BoxShape.circle,
              border: Border.all(color: MagicColors.leaf.withOpacity(0.6), width: 2),
            ),
            child: const Icon(Icons.add, color: Colors.white70, size: 24),
          ),
        ),
      );
    }

    return _buildActiveSlot(context, index, slot, centeredLeft, centeredTop, size);
  }

  Widget _buildLockedSlot(BuildContext context, int index, double left, double top, double size) {
    final costs = widget.game.getGardenSlotUnlockCost(index);
    final goldCost = costs["gold"] ?? 0;
    final crystalCost = costs["crystal"] ?? 0;
    final canAffordGold = widget.game.gold >= goldCost && goldCost > 0;
    final canAffordCrystal = widget.game.crystals >= crystalCost && crystalCost > 0;
    final isFree = goldCost == 0 && crystalCost == 0;

    return Positioned(
      left: left,
      top: top,
      width: size,
      height: size,
      child: GestureDetector(
        onTap: () => _showUnlockSlotDialog(context, index, goldCost, crystalCost),
        child: Container(
          decoration: BoxDecoration(
            color: Colors.black.withOpacity(0.4),
            shape: BoxShape.circle,
            border: Border.all(
              color: (canAffordGold || canAffordCrystal || isFree)
                  ? MagicColors.crystal.withOpacity(0.8)
                  : Colors.grey.withOpacity(0.3),
              width: 2,
            ),
          ),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(Icons.lock_open, color: Colors.white54, size: 16),
              if (isFree)
                const Text('FREE', style: TextStyle(color: MagicColors.leaf, fontSize: 8, fontWeight: FontWeight.bold))
              else if (goldCost > 0)
                Text('$goldCost g', style: TextStyle(color: canAffordGold ? MagicColors.gold : Colors.grey, fontSize: 8)),
              if (crystalCost > 0)
                Row(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Text('$crystalCost', style: TextStyle(color: canAffordCrystal ? MagicColors.crystal : Colors.grey, fontSize: 8)),
                    const Icon(Icons.diamond, color: MagicColors.crystal, size: 6),
                  ],
                ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildActiveSlot(BuildContext context, int index, IdleGardenSlot slot, double left, double top, double size) {
    final seed = seeds[slot.seedId];
    final progress = widget.game.getGardenSlotProgress(index);

    return Positioned(
      left: left,
      top: top,
      width: size,
      height: size,
      child: GestureDetector(
        onTap: () => _showSlotStats(context, index),
        child: Container(
          decoration: BoxDecoration(
            gradient: RadialGradient(
              colors: [seed.color.withOpacity(0.8), seed.color.withOpacity(0.3)],
            ),
            shape: BoxShape.circle,
            border: Border.all(color: seed.color, width: 2),
          ),
          child: Stack(
            children: [
              Center(
                child: SizedBox(
                  width: size * 0.9,
                  height: size * 0.9,
                  child: CircularProgressIndicator(
                    value: progress,
                    strokeWidth: 3,
                    backgroundColor: Colors.transparent,
                    valueColor: AlwaysStoppedAnimation<Color>(Colors.white.withOpacity(0.5)),
                  ),
                ),
              ),
              Center(
                child: Column(
                  mainAxisAlignment: MainAxisAlignment.center,
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Text(seed.icon, style: TextStyle(fontSize: size * 0.4)),
                    if (progress < 1)
                      Text(
                        widget.game.getGardenSlotTimeLeft(index),
                        style: TextStyle(color: Colors.white70, fontSize: size * 0.15),
                      ),
                  ],
                ),
              ),
              Positioned(
                right: 0,
                top: 0,
                child: GestureDetector(
                  onTap: () => widget.game.stopIdleGarden(index),
                  child: Container(
                    padding: EdgeInsets.all(size * 0.05),
                    decoration: const BoxDecoration(color: Colors.red, shape: BoxShape.circle),
                    child: Icon(Icons.close, color: Colors.white, size: size * 0.15),
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildLabDoor(BoxConstraints constraints) {
    final maxWidth = constraints.maxWidth;
    final maxHeight = constraints.maxHeight;
    final config = GardenLayoutConfig.labDoor;

    final width = maxWidth * config['width']!;
    final height = maxHeight * config['height']!;
    final left = maxWidth * config['left']! - (width / 2); // Center on left value
    final bottom = maxHeight * config['bottom']!;
    final top = maxHeight - bottom - height;

    return Positioned(
      left: left,
      top: top,
      width: width,
      height: height,
      child: GestureDetector(
        onTap: () => widget.onNavigate(0),
        child: Container(
          decoration: BoxDecoration(
            color: Colors.brown.withOpacity(0.3),
            borderRadius: BorderRadius.circular(10),
            border: Border.all(color: Colors.brown.shade300, width: 2),
          ),
          child: const Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              Icon(Icons.door_front_door_outlined, color: Colors.white70, size: 24),
              Text(
                'To Lab',
                style: TextStyle(color: Colors.white, fontSize: 10, fontWeight: FontWeight.bold),
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildDebugToggle(BoxConstraints constraints) {
    return Positioned(
      right: constraints.maxWidth * 0.04,
      top: constraints.maxHeight * 0.20,
      child: FloatingActionButton.small(
        onPressed: () => setState(() => _showDebugger = !_showDebugger),
        backgroundColor: _showDebugger ? Colors.red : Colors.green,
        child: Icon(_showDebugger ? Icons.close : Icons.tune),
      ),
    );
  }

  Widget _buildDebugOverlay(BoxConstraints constraints) {
    final maxWidth = constraints.maxWidth;
    final maxHeight = constraints.maxHeight;
    final size = maxWidth * GardenLayoutConfig.slotSizePercent;

    return Stack(
      children: List.generate(10, (index) {
        final pos = _slotPositions[index]!;
        final left = maxWidth * pos[0] - (size / 2);
        final top = maxHeight * pos[1] - (size / 2);

        return Positioned(
          left: left,
          top: top,
          width: size,
          height: size,
          child: Container(
            decoration: BoxDecoration(
              border: Border.all(color: Colors.green, width: 2),
              color: Colors.green.withOpacity(0.2),
              shape: BoxShape.circle,
            ),
            child: Center(
              child: Text(
                '$index',
                style: const TextStyle(color: Colors.green, fontSize: 12, fontWeight: FontWeight.bold),
              ),
            ),
          ),
        );
      }),
    );
  }

  Widget _buildPercentageDebugger(BoxConstraints constraints) {
    final offsets = _slotPositions[_selectedSlot]!;
    final maxWidth = constraints.maxWidth;
    final maxHeight = constraints.maxHeight;

    return Positioned(
      right: constraints.maxWidth * 0.04,
      top: constraints.maxHeight * 0.26,
      width: constraints.maxWidth * 0.70,
      child: Container(
        padding: const EdgeInsets.all(16),
        decoration: BoxDecoration(
          color: Colors.black87,
          borderRadius: BorderRadius.circular(16),
          border: Border.all(color: Colors.white24),
        ),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                const Text(
                  '🔧 Garden Slot Tuner',
                  style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold),
                ),
                IconButton(
                  icon: const Icon(Icons.copy, color: Colors.green),
                  onPressed: () {
                    final code = _slotPositions.entries
                        .map((e) => '    ${e.key}: [${e.value[0].toStringAsFixed(2)}, ${e.value[1].toStringAsFixed(2)}],')
                        .join('\n');
                    Clipboard.setData(ClipboardData(
                      text: 'static const Map<int, List<double>> slotPositions = {\n$code\n  };',
