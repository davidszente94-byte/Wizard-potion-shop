              ),
            ),
            const SizedBox(height: 16),
            Text('Horizontal (0=left, 1=right)', style: TextStyle(color: Colors.grey[400], fontSize: 12)),
            Slider(
              value: offsets[0],
              min: 0.0,
              max: 1.0,
              divisions: 100,
              activeColor: Colors.blue,
              label: '${(offsets[0] * 100).toStringAsFixed(0)}%',
              onChanged: (v) => setState(() => _slotPositions[_selectedSlot]![0] = v),
            ),
            Text('Vertical (0=top, 1=bottom)', style: TextStyle(color: Colors.grey[400], fontSize: 12)),
            Slider(
              value: offsets[1],
              min: 0.0,
              max: 1.0,
              divisions: 100,
              activeColor: Colors.orange,
              label: '${(offsets[1] * 100).toStringAsFixed(0)}%',
              onChanged: (v) => setState(() => _slotPositions[_selectedSlot]![1] = v),
            ),
            const SizedBox(height: 8),
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceEvenly,
              children: [
                _buildPresetButton('Far Left', 0.10, offsets[1]),
                _buildPresetButton('Center', 0.50, offsets[1]),
                _buildPresetButton('Far Right', 0.90, offsets[1]),
