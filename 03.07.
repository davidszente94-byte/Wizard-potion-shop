  Widget _buildDebugOverlay(BoxConstraints constraints) {
    final maxWidth = constraints.maxWidth;
    final maxHeight = constraints.maxHeight;

    final tableConfigs = {
      'table1': LabLayoutConfig.table1,
      'table2': LabLayoutConfig.table2,
      'table3': LabLayoutConfig.table3,
      'table4': LabLayoutConfig.table4,
    };

    final colors = {
      'table1': Colors.cyan,
      'table2': Colors.pink,
      'table3': Colors.lime,
      'table4': Colors.orange,
    };

    return Stack(
      children: tableConfigs.entries.map((entry) {
        final name = entry.key;
        final config = entry.value;
        final color = colors[name]!;

        final left = maxWidth * config['left']!;
        final bottom = maxHeight * config['bottom']!;
        final width = maxWidth * config['width']!;
        // Calculate height from aspect ratio (same as _buildTable)
        final height = width / LabLayoutConfig.tableAspectRatio;
        // Convert bottom to top for Positioned widget
        final top = maxHeight - bottom - height;

        return Positioned(
          left: left,
          top: top,
          width: width,
          height: height,
          child: Container(
            decoration: BoxDecoration(
              border: Border.all(color: color, width: 3),
              color: color.withOpacity(0.2),
            ),
            child: Center(
              child: Text(
                name.toUpperCase(),
                style: TextStyle(color: color, fontSize: 12),
              ),
            ),
          ),
        );
      }).toList(),
    );
  }

