          mainAxisSize: MainAxisSize.min,
          children: [
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                // Gold
                _resourceItem(Icons.monetization_on, MagicColors.gold, game.gold),
                // Level & XP
                Expanded(
                  child: Padding(
                    padding: const EdgeInsets.symmetric(horizontal: 8),
                    child: Column(
                      children: [
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                          decoration: BoxDecoration(
                            color: MagicColors.crystal.withOpacity(0.3),
                            borderRadius: BorderRadius.circular(8),
                          ),
                          child: Text(
                            'Level ${game.level}',
                            style: const TextStyle(
                              color: MagicColors.textLight,
                              fontWeight: FontWeight.bold,
                              fontSize: 12,
                            ),
                          ),
                        ),
                        const SizedBox(height: 4),
                        SizedBox(
                          height: 6,
                          child: LinearProgressIndicator(
                            value: game.xpProgress(),
                            backgroundColor: Colors.black26,
                            valueColor: const AlwaysStoppedAnimation<Color>(MagicColors.crystal),
                          ),
                        ),
                      ],
                    ),
                  ),
                ),
                // Crystals
                _resourceItem(Icons.diamond, MagicColors.crystal, game.crystals),
              ],
            ),
            // Boosts row - single line
            if (game.goldBoostDuration > 0 || game.xpBoostDuration > 0 ||
                game.plantSpeedBoostDuration > 0 || game.potionSpeedBoostDuration > 0)
              Padding(
                padding: const EdgeInsets.only(top: 4),
                child: SingleChildScrollView(
                  scrollDirection: Axis.horizontal,
                  child: Row(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      if (game.goldBoostDuration > 0)
                        _boostChip(Icons.monetization_on, Colors.orange, 'Gold+'),
                      if (game.xpBoostDuration > 0)
                        _boostChip(Icons.trending_up, Colors.blue, 'XP+'),
                      if (game.plantSpeedBoostDuration > 0)
                        _boostChip(Icons.eco, MagicColors.leaf, 'Grow+'),
                      if (game.potionSpeedBoostDuration > 0)
                        _boostChip(Icons.local_fire_department, MagicColors.fire, 'Brew+'),
                    ],
                  ),
                ),
              ),
          ],
        ),
      ),
    );
  }

  Widget _resourceItem(IconData icon, Color color, int value) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 4),
      decoration: BoxDecoration(
        color: color.withOpacity(0.2),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: color.withOpacity(0.5)),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, color: color, size: 16),
          const SizedBox(width: 4),
          Text(
            _formatNumber(value),
            style: TextStyle(color: color, fontWeight: FontWeight.bold, fontSize: 14),
          ),
        ],
      ),
    );
  }

  Widget _boostChip(IconData icon, Color color, String label) {
    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 4),
      padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
      decoration: BoxDecoration(
        color: color.withOpacity(0.2),
        borderRadius: BorderRadius.circular(6),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, color: color, size: 10),
          const SizedBox(width: 2),
          Text(label, style: TextStyle(color: color, fontSize: 9)),
        ],
      ),
    );
  }

  String _formatNumber(int n) {
    if (n >= 1000000) return '${(n/1000000).toStringAsFixed(1)}M';
    if (n >= 1000) return '${(n/1000).toStringAsFixed(1)}k';
    return n.toString();
  }
}

