  Widget _buildGardenPlot(int index) {
    if (index >= widget.game.unlockedSlots) {
      final costs = widget.game.getGardenSlotUnlockCost(index);
      final goldCost = costs["gold"] ?? 0;
      final crystalCost = costs["crystal"] ?? 0;
      final canAffordGold = widget.game.gold >= goldCost && goldCost > 0;
      final canAffordCrystal = widget.game.crystals >= crystalCost && crystalCost > 0;
      final isFree = goldCost == 0 && crystalCost == 0;

      return GestureDetector(
        onTap: () => _showUnlockSlotDialog(context, index, goldCost, crystalCost),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            color: const Color(0xFF5D4037).withOpacity(0.5),
            borderRadius: BorderRadius.circular(16),
            border: Border.all(
              color: (canAffordGold || canAffordCrystal || isFree)
                  ? MagicColors.crystal.withOpacity(0.6)
                  : Colors.grey.withOpacity(0.3),
              width: 2,
            ),
          ),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(Icons.lock_open, color: Colors.grey),
              const SizedBox(height: 4),
              if (isFree)
                const Text('FREE', style: TextStyle(color: MagicColors.leaf, fontSize: 10, fontWeight: FontWeight.bold))
              else if (goldCost > 0 || crystalCost > 0)
                Column(
                  children: [
                    if (goldCost > 0)
                      Text(
                        '$goldCost g',
                        style: TextStyle(
                          color: canAffordGold ? MagicColors.gold : Colors.grey,
                          fontSize: 10,
                        ),
                      ),
                    if (crystalCost > 0)
                      Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Text(
                            '$crystalCost',
                            style: TextStyle(
                              color: canAffordCrystal ? MagicColors.crystal : Colors.grey,
                              fontSize: 10,
                            ),
                          ),
                          const Icon(Icons.diamond, color: MagicColors.crystal, size: 10),
                        ],
                      ),
                  ],
                ),
            ],
          ),
        ),
      );
    }

    final slot = widget.game.gardenSlots[index];
    if (slot == null) {
      return GestureDetector(
        onTap: () => _showSeedSelection(context, index),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            gradient: LinearGradient(
              colors: [
                const Color(0xFF8B4513).withOpacity(0.6),
                const Color(0xFFA0522D).withOpacity(0.4),
              ],
            ),
            borderRadius: BorderRadius.circular(16),
            border: Border.all(color: MagicColors.leaf.withOpacity(0.5)),
          ),
          child: const Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              Icon(Icons.add, color: MagicColors.leaf),
              SizedBox(height: 4),
              Text('Plant', style: TextStyle(color: MagicColors.textMuted, fontSize: 10)),
            ],
          ),
        ),
      );
    }

    final seed = seeds[slot.seedId];
    final progress = widget.game.getGardenSlotProgress(index);

    return GestureDetector(
      onTap: () => _showSlotStats(context, index),
      child: Container(
        width: 80,
        height: 100,
        decoration: BoxDecoration(
          gradient: LinearGradient(
            colors: [
              seed.color.withOpacity(0.3),
              const Color(0xFF5D4037).withOpacity(0.5),
            ],
          ),
          borderRadius: BorderRadius.circular(16),
          border: Border.all(color: seed.color.withOpacity(0.6), width: 2),
          boxShadow: [
            BoxShadow(
              color: seed.color.withOpacity(0.2),
              blurRadius: 10,
            ),
          ],
        ),
        child: Stack(
          children: [
            // Growth visualization
            Positioned.fill(
              child: CustomPaint(
                painter: GardenPlotPainter(
                  isPlanted: true,
                  growthProgress: progress,
                  plantColor: seed.color,
                ),
              ),
            ),
            // UI overlay
            Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Container(
                    padding: const EdgeInsets.all(6),
                    decoration: BoxDecoration(
                      color: Colors.black54,
                      shape: BoxShape.circle,
                    ),
                    child: Text(seed.icon, style: const TextStyle(fontSize: 20)),
                  ),
                  const SizedBox(height: 4),
                  Container(
                    padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                    decoration: BoxDecoration(
                      color: Colors.black54,
                      borderRadius: BorderRadius.circular(8),
                    ),
                    child: Text(
                      seed.name.split(' ')[0],
                      style: const TextStyle(color: MagicColors.textLight, fontSize: 8),
                      textAlign: TextAlign.center,
                    ),
                  ),
                  if (progress < 1)
                    Container(
                      margin: const EdgeInsets.only(top: 4),
                      padding: const EdgeInsets.symmetric(horizontal: 4, vertical: 2),
                      decoration: BoxDecoration(
                        color: Colors.black87,
                        borderRadius: BorderRadius.circular(4),
                      ),
                      child: Text(
                        widget.game.getGardenSlotTimeLeft(index),
                        style: const TextStyle(color: MagicColors.textMuted, fontSize: 8),
                      ),
                    ),
                ],
              ),
            ),
            Positioned(
              top: 4,
              right: 4,
              child: GestureDetector(
                onTap: () => widget.game.stopIdleGarden(index),
                child: Container(
                  padding: const EdgeInsets.all(2),
                  decoration: BoxDecoration(
                    color: Colors.red.withOpacity(0.3),
                    shape: BoxShape.circle,
                  ),
                  child: const Icon(Icons.close, color: Colors.red, size: 14),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }

  void _showUnlockSlotDialog(BuildContext context, int index, int goldCost, int crystalCost) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text('Unlock Garden Slot ${index + 1}', style: const TextStyle(color: MagicColors.textLight)),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('Choose payment method:', style: TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 16),
            if (goldCost > 0)
              ListTile(
                leading: const Icon(Icons.monetization_on, color: MagicColors.gold),
                title: Text('$goldCost Gold', style: const TextStyle(color: MagicColors.textLight)),
                trailing: widget.game.gold >= goldCost
                    ? ElevatedButton(
                  onPressed: () {
                    widget.game.unlockGardenSlotWithGold();
                    Navigator.pop(ctx);
                  },
                  child: const Text('Buy'),
                )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
            if (crystalCost > 0)
              ListTile(
                leading: const Icon(Icons.diamond, color: MagicColors.crystal),
                title: Text('$crystalCost Crystals', style: const TextStyle(color: MagicColors.textLight)),
                trailing: widget.game.crystals >= crystalCost
                    ? ElevatedButton(
                  onPressed: () {
                    widget.game.unlockGardenSlotWithCrystals();
                    Navigator.pop(ctx);
                  },
                  child: const Text('Buy'),
                )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
        ],
      ),
    );
  }

  void _showSeedSelection(BuildContext context, int slotIndex) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Seed', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          child: ListView(
            shrinkWrap: true,
            children: seeds.map((s) {
              final unlocked = widget.game.isSeedUnlocked(s.id);
              final canAfford = s.cost == 0 || widget.game.gold >= s.cost;
              final growTime = widget.game.getGrowTime(s.plantId);

              if (!unlocked) {
                return ListTile(
                  leading: const Icon(Icons.lock, color: Colors.grey),
                  title: Text(s.name, style: const TextStyle(color: Colors.grey)),
                  subtitle: Text('Unlocks at Level ${s.unlockLevel}', style: const TextStyle(color: Colors.grey)),
                );
              }

              return ListTile(
                leading: Container(
                  width: 40,
                  height: 40,
                  decoration: BoxDecoration(
                    color: s.color.withOpacity(0.2),
                    shape: BoxShape.circle,
                    border: Border.all(color: s.color),
                  ),
                  child: Center(child: Text(s.icon, style: const TextStyle(fontSize: 20))),
                ),
                title: Text(s.name, style: TextStyle(color: canAfford ? MagicColors.textLight : Colors.grey)),
                subtitle: Text(
                  s.cost == 0 ? 'Free • ${plants[s.plantId].xpValue} XP' : '${s.cost}g/cycle • ${plants[s.plantId].xpValue} XP',
                  style: TextStyle(color: canAfford ? MagicColors.textMuted : Colors.red),
                ),
                trailing: Container(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: s.color.withOpacity(0.2),
                    borderRadius: BorderRadius.circular(8),
                  ),
                  child: Text(
                    formatDuration(growTime),
                    style: TextStyle(color: s.color, fontWeight: FontWeight.bold),
                  ),
                ),
                onTap: canAfford ? () {
                  widget.game.startIdleGarden(slotIndex, s.id);
                  Navigator.pop(ctx);
                } : null,
              );
            }).toList(),
          ),
        ),
      ),
