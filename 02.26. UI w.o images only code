  Widget _getScreen() {
    switch (screen) {
      case 0:
        return AlchemyLabScreen(
          game: game,
          onGoToGarden: () => navigateTo(1),
          onOpenRecipeBook: () => navigateTo(3),
          onLevelUp: showLevelUpDialog,
        );
      case 1:
        return GardenScreen(
          game: game,
          onGoToLab: () => navigateTo(0),
          onLevelUp: showLevelUpDialog,
        );
      case 2:
        return ShopScreen(
          game: game,
          onBack: () => navigateTo(0),
        );
      case 3:
        return RecipeBookScreen(
          game: game,
          onBack: () => navigateTo(0),
        );
      default:
        return AlchemyLabScreen(
          game: game,
          onGoToGarden: () => navigateTo(1),
          onOpenRecipeBook: () => navigateTo(3),
          onLevelUp: showLevelUpDialog,
