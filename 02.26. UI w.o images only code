                title: Text('$crystalCost Crystals', style: const TextStyle(color: MagicColors.textLight)),
                trailing: widget.game.crystals >= crystalCost
                    ? ElevatedButton(
                  onPressed: () {
                    widget.game.unlockBrewSlotWithCrystals();
                    Navigator.pop(ctx);
                  },
                  child: const Text('Buy'),
                )
                    : const Text('Insufficient', style: TextStyle(color: Colors.red, fontSize: 12)),
              ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
        ],
      ),
    );
  }

  void _showPotionSelection(BuildContext context, int slotIndex) {
    final unlockedRecipes = allRecipes.where((r) => widget.game.isRecipeUnlocked(r.key)).toList();

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: const Text('Select Potion', style: TextStyle(color: MagicColors.textLight)),
        content: SizedBox(
          width: double.maxFinite,
          height: 400,
          child: ListView.builder(
            itemCount: unlockedRecipes.length,
            itemBuilder: (context, index) {
              final recipe = unlockedRecipes[index];
              final brewTime = widget.game.getBrewTime(recipe);
              bool hasMaterials = widget.game.storage[recipe.plantTier] >= 3;

              return ListTile(
                leading: Container(
                  width: 50,
                  height: 50,
                  decoration: BoxDecoration(
                    color: rarityColor(recipe.rarity).withOpacity(0.2),
                    shape: BoxShape.circle,
                    border: Border.all(color: rarityColor(recipe.rarity)),
                  ),
                  child: Center(child: Text(recipe.icon, style: const TextStyle(fontSize: 24))),
                ),
                title: Text(recipe.name, style: TextStyle(color: hasMaterials ? MagicColors.textLight : Colors.grey)),
                subtitle: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      children: [
                        Container(
                          margin: const EdgeInsets.only(right: 2),
                          padding: const EdgeInsets.all(2),
                          decoration: BoxDecoration(
                            color: plants[recipe.plantTier].color.withOpacity(0.3),
                            borderRadius: BorderRadius.circular(4),
                          ),
                          child: Text('${plants[recipe.plantTier].icon} x3', style: const TextStyle(fontSize: 12)),
                        ),
                      ],
                    ),
                    Text(
                      '${recipe.sellPrice}g • ${formatDuration(brewTime)} • ${recipe.xpValue} XP',
                      style: TextStyle(color: hasMaterials ? MagicColors.gold : Colors.red, fontSize: 11),
                    ),
                  ],
                ),
                trailing: Container(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: rarityColor(recipe.rarity).withOpacity(0.3),
                    borderRadius: BorderRadius.circular(8),
                  ),
                  child: Text(
                    recipe.rarity.name.toUpperCase(),
                    style: TextStyle(
                      color: rarityColor(recipe.rarity),
                      fontSize: 9,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ),
                onTap: hasMaterials ? () {
                  widget.game.startIdleBrew(slotIndex, recipe.key);
                  Navigator.pop(ctx);
                } : null,
              );
            },
          ),
        ),
      ),
    );
  }

  void _showBrewStats(BuildContext context, int index) {
    final slot = widget.game.brewSlots[index];
    if (slot == null) return;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return;

    final goldPerHour = widget.game.getBrewGoldPerHour(index);

    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: MagicColors.surface,
        title: Text(recipe.name, style: TextStyle(color: rarityColor(recipe.rarity))),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text('Cycles: ${slot.cyclesCompleted}', style: const TextStyle(color: MagicColors.textMuted)),
            const SizedBox(height: 12),
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: MagicColors.gold.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: MagicColors.gold),
              ),
              child: Column(
                children: [
                  const Text('Gold/Hour', style: TextStyle(color: MagicColors.textMuted, fontSize: 12)),
                  Text(
                    '${_formatNumber(goldPerHour.round())}',
                    style: const TextStyle(
                      color: MagicColors.gold,
                      fontSize: 24,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 12),
            Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: plants[recipe.plantTier].color.withOpacity(0.2),
                borderRadius: BorderRadius.circular(8),
              ),
              child: Row(
                mainAxisSize: MainAxisSize.min,
                children: [
                  Text(plants[recipe.plantTier].icon),
                  const SizedBox(width: 4),
                  Text('${plants[recipe.plantTier].name} x3', style: const TextStyle(fontSize: 12)),
                ],
              ),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }

  Widget _buildInventory() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: MagicColors.surface.withOpacity(0.7),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: MagicColors.fire.withOpacity(0.3)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: MagicColors.fire.withOpacity(0.2),
                  shape: BoxShape.circle,
                ),
                child: const Icon(Icons.inventory_2, color: MagicColors.fire, size: 20),
              ),
              const SizedBox(width: 12),
              const Text(
                'Ingredients',
                style: TextStyle(
                  color: MagicColors.textLight,
                  fontWeight: FontWeight.bold,
                  fontSize: 16,
                ),
              ),
            ],
          ),
          const SizedBox(height: 12),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: plants.map((plant) {
              final count = widget.game.storage[plant.id];
              if (count == 0) return const SizedBox.shrink();
              final canBrew = count >= 3;
              return Container(
                padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
                decoration: BoxDecoration(
                  gradient: LinearGradient(
                    colors: [
                      plant.color.withOpacity(canBrew ? 0.4 : 0.1),
                      plant.color.withOpacity(canBrew ? 0.2 : 0.05),
                    ],
                  ),
                  borderRadius: BorderRadius.circular(16),
                  border: Border.all(
                    color: plant.color.withOpacity(canBrew ? 0.8 : 0.3),
                    width: 2,
                  ),
                  boxShadow: canBrew ? [
                    BoxShadow(
                      color: plant.color.withOpacity(0.3),
                      blurRadius: 8,
                    ),
                  ] : null,
                ),
                child: Row(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Text(plant.icon),
                    const SizedBox(width: 6),
                    Text(
                      '${plant.name}: $count',
                      style: TextStyle(
                        color: canBrew ? plant.color : Colors.grey,
                        fontSize: 12,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                  ],
                ),
              );
            }).toList(),
          ),
        ],
      ),
    );
  }

  String _formatNumber(int n) {
    if (n >= 1000000) return '${(n/1000000).toStringAsFixed(1)}M';
    if (n >= 1000) return '${(n/1000).toStringAsFixed(1)}k';
    return n.toString();
  }
}

