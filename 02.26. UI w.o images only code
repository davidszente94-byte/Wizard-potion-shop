  void startTicker() {
    _ticker?.cancel();
    _ticker = Timer.periodic(const Duration(seconds: 1), (_) {
      _updateBoosts();
      processIdleGarden();
      processIdleBrew();
      notifyListeners();
    });
  }

  void _updateBoosts() {
    final now = DateTime.now().millisecondsSinceEpoch;
    activeBoosts.removeWhere((boost) => boost.endTime <= now);
  }

  @override
  void dispose() {
    _ticker?.cancel();
    super.dispose();
  }

  bool isBoostActive(BoostType type) {
    final now = DateTime.now().millisecondsSinceEpoch;
    return activeBoosts.any((b) => b.type == type && b.endTime > now);
  }

  double getBoostMultiplier(BoostType type150, BoostType type200, double boost150, double boost200) {
    if (isBoostActive(type200)) return boost200;
    if (isBoostActive(type150)) return boost150;
    return 1.0;
  }

  int get goldBoostDuration {
    final now = DateTime.now().millisecondsSinceEpoch;
    final goldBoosts = activeBoosts.where((b) =>
    b.type == BoostType.gold150 || b.type == BoostType.gold200);
    if (goldBoosts.isEmpty) return 0;
    return ((goldBoosts.map((b) => b.endTime).reduce((a, b) => a > b ? a : b) - now) / 1000).ceil();
  }

  int get xpBoostDuration {
    final now = DateTime.now().millisecondsSinceEpoch;
    final xpBoosts = activeBoosts.where((b) =>
    b.type == BoostType.xp150 || b.type == BoostType.xp200);
    if (xpBoosts.isEmpty) return 0;
    return ((xpBoosts.map((b) => b.endTime).reduce((a, b) => a > b ? a : b) - now) / 1000).ceil();
  }

  int get plantSpeedBoostDuration {
    final now = DateTime.now().millisecondsSinceEpoch;
    final boosts = activeBoosts.where((b) =>
    b.type == BoostType.plantSpeed150 || b.type == BoostType.plantSpeed200);
    if (boosts.isEmpty) return 0;
    return ((boosts.map((b) => b.endTime).reduce((a, b) => a > b ? a : b) - now) / 1000).ceil();
  }

  int get potionSpeedBoostDuration {
    final now = DateTime.now().millisecondsSinceEpoch;
    final boosts = activeBoosts.where((b) =>
    b.type == BoostType.potionSpeed150 || b.type == BoostType.potionSpeed200);
    if (boosts.isEmpty) return 0;
    return ((boosts.map((b) => b.endTime).reduce((a, b) => a > b ? a : b) - now) / 1000).ceil();
  }

  double getGrowSpeedMultiplier() {
    double baseMultiplier = 1.0;
    for (int i = 1; i < growSpeedLevel && i < speedMultipliers.length; i++) {
      baseMultiplier *= speedMultipliers[i];
    }
    double boostMult = getBoostMultiplier(BoostType.plantSpeed150, BoostType.plantSpeed200, 1.5, 2.0);
    return baseMultiplier / boostMult;
  }

  double getBrewSpeedMultiplier() {
    double baseMultiplier = 1.0;
    for (int i = 1; i < brewSpeedLevel && i < speedMultipliers.length; i++) {
      baseMultiplier *= speedMultipliers[i];
    }
    double boostMult = getBoostMultiplier(BoostType.potionSpeed150, BoostType.potionSpeed200, 1.5, 2.0);
    return baseMultiplier / boostMult;
  }

  Duration getGrowTime(int plantId) {
    final baseTime = plants[plantId].baseGrowTime.inSeconds;
    final multiplier = getGrowSpeedMultiplier();
    return Duration(seconds: (baseTime * multiplier).round());
  }

  Duration getBrewTime(Recipe recipe) {
    final baseTime = recipe.baseBrewTime;
    final multiplier = getBrewSpeedMultiplier();
    return Duration(seconds: (baseTime * multiplier).round());
  }

  void processIdleGarden() {
    bool changed = false;
    final now = DateTime.now().millisecondsSinceEpoch;

    for (int i = 0; i < maxGardenSlots; i++) {
      final slot = gardenSlots[i];
      if (slot == null || !slot.isActive) continue;

      final seed = seeds[slot.seedId];
      final growTime = getGrowTime(seed.plantId).inSeconds;

      final elapsed = (now - slot.startTime) ~/ 1000;
      int possibleCycles = elapsed ~/ growTime;

      int affordableCycles = possibleCycles;
      if (seed.cost > 0) {
        int maxAffordable = gold ~/ seed.cost;
        affordableCycles = possibleCycles.clamp(0, maxAffordable);
      }

      for (int c = 0; c < affordableCycles; c++) {
        if (seed.cost > 0) gold -= seed.cost;
        storage[seed.plantId]++;
        slot.cyclesCompleted++;

        int xpGain = plants[seed.plantId].xpValue;
        double xpMult = getBoostMultiplier(BoostType.xp150, BoostType.xp200, 1.5, 2.0);
        xpGain = (xpGain * xpMult).round();

        gainXP(xpGain);
        changed = true;
      }

      if (affordableCycles > 0) {
        slot.startTime += affordableCycles * growTime * 1000;
      }

      if (seed.cost > 0 && gold < seed.cost) {
        slot.isActive = false;
      }
    }

    if (changed) save();
  }

  double getGardenSlotProgress(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null) return 0;
    final seed = seeds[slot.seedId];
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) / 1000;
    final growTime = getGrowTime(seed.plantId).inSeconds;
    return (elapsed / growTime).clamp(0.0, 1.0);
  }

  String getGardenSlotTimeLeft(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null) return "";
    final seed = seeds[slot.seedId];
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) ~/ 1000;
    final growTime = getGrowTime(seed.plantId).inSeconds;
    final remaining = growTime - (elapsed % growTime);
    return formatTime(remaining);
  }

  double getGardenPlantsPerHour(int slotIndex) {
    final slot = gardenSlots[slotIndex];
    if (slot == null) return 0;
    final seed = seeds[slot.seedId];
    final growTime = getGrowTime(seed.plantId).inSeconds;
    if (growTime <= 0) return 0;
    return 3600.0 / growTime;
  }

  void startIdleGarden(int slotIndex, int seedId) {
    if (slotIndex >= unlockedSlots) return;
    if (level < seeds[seedId].unlockLevel) return;

    gardenSlots[slotIndex] = IdleGardenSlot(
      seedId: seedId,
      startTime: DateTime.now().millisecondsSinceEpoch,
    );
    save();
    notifyListeners();
  }

  void stopIdleGarden(int slotIndex) {
    gardenSlots[slotIndex] = null;
    save();
    notifyListeners();
  }

  void processIdleBrew() {
    bool changed = false;
    final now = DateTime.now().millisecondsSinceEpoch;

    for (int i = 0; i < maxBrewSlots; i++) {
      final slot = brewSlots[i];
      if (slot == null || !slot.isActive) continue;

      final recipe = getRecipeByKey(slot.recipeKey);
      if (recipe == null) continue;

      final brewTime = getBrewTime(recipe).inSeconds;
      final elapsed = (now - slot.startTime) ~/ 1000;
      int possibleCycles = elapsed ~/ brewTime;

      int plantId = recipe.plantTier;
      int available = storage[plantId] ~/ 3;
      int affordableCycles = possibleCycles.clamp(0, available);

      for (int c = 0; c < affordableCycles; c++) {
        storage[plantId] -= 3;

        int sellPrice = recipe.sellPrice;
        double goldMult = getBoostMultiplier(BoostType.gold150, BoostType.gold200, 1.5, 2.0);
        sellPrice = (sellPrice * goldMult).round();

        gold += sellPrice;

        int xpGain = recipe.xpValue;
        double xpMult = getBoostMultiplier(BoostType.xp150, BoostType.xp200, 1.5, 2.0);
        xpGain = (xpGain * xpMult).round();

        gainXP(xpGain);

        slot.cyclesCompleted++;
        changed = true;
      }

      if (affordableCycles > 0) {
        slot.startTime += affordableCycles * brewTime * 1000;
      }

      if (storage[recipe.plantTier] < 3) slot.isActive = false;
    }

    if (changed) {
      save();
      notifyListeners();
    }
  }

  double getBrewSlotProgress(int slotIndex) {
    final slot = brewSlots[slotIndex];
    if (slot == null) return 0;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return 0;
    final brewTime = getBrewTime(recipe).inSeconds;
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) / 1000;
    return (elapsed / brewTime).clamp(0.0, 1.0);
  }

  String getBrewSlotTimeLeft(int slotIndex) {
    final slot = brewSlots[slotIndex];
    if (slot == null) return "";
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return "";
    final brewTime = getBrewTime(recipe).inSeconds;
    final now = DateTime.now().millisecondsSinceEpoch;
    final elapsed = (now - slot.startTime) ~/ 1000;
    final remaining = brewTime - (elapsed % brewTime);
    return formatTime(remaining);
  }

  double getBrewGoldPerHour(int slotIndex) {
    final slot = brewSlots[slotIndex];
    if (slot == null) return 0;
    final recipe = getRecipeByKey(slot.recipeKey);
    if (recipe == null) return 0;
    final brewTime = getBrewTime(recipe).inSeconds;
    if (brewTime <= 0) return 0;
    double cyclesPerHour = 3600.0 / brewTime;
    double goldMult = getBoostMultiplier(BoostType.gold150, BoostType.gold200, 1.5, 2.0);
    return (recipe.sellPrice * goldMult) * cyclesPerHour;
  }

