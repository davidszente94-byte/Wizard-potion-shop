  Widget _buildCauldron(int index) {
    if (index >= widget.game.unlockedBrewSlots) {
      final costs = widget.game.getBrewSlotUnlockCost(index);
      final goldCost = costs["gold"] ?? 0;
      final crystalCost = costs["crystal"] ?? 0;
      final canAffordGold = widget.game.gold >= goldCost && goldCost > 0;
      final canAffordCrystal = widget.game.crystals >= crystalCost && crystalCost > 0;
      final isFree = goldCost == 0 && crystalCost == 0;

      return GestureDetector(
        onTap: () => _showUnlockSlotDialog(context, index, goldCost, crystalCost),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            gradient: LinearGradient(
              colors: [
                Colors.grey.shade800,
                Colors.grey.shade900,
              ],
            ),
            borderRadius: const BorderRadius.only(
              bottomLeft: Radius.circular(40),
              bottomRight: Radius.circular(40),
              topLeft: Radius.circular(16),
              topRight: Radius.circular(16),
            ),
            border: Border.all(
              color: (canAffordGold || canAffordCrystal || isFree)
                  ? MagicColors.crystal.withOpacity(0.6)
                  : Colors.grey.shade700,
              width: 3,
            ),
          ),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(Icons.lock, color: Colors.grey),
              const SizedBox(height: 8),
              if (isFree)
                const Text('FREE', style: TextStyle(color: MagicColors.leaf, fontSize: 10, fontWeight: FontWeight.bold))
              else ...[
                if (goldCost > 0)
                  Text(
                    '$goldCost g',
                    style: TextStyle(
                      color: canAffordGold ? MagicColors.gold : Colors.grey,
                      fontSize: 10,
                    ),
                  ),
                if (crystalCost > 0)
                  Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Text(
                        '$crystalCost',
                        style: TextStyle(
                          color: canAffordCrystal ? MagicColors.crystal : Colors.grey,
                          fontSize: 10,
                        ),
                      ),
                      const Icon(Icons.diamond, color: MagicColors.crystal, size: 10),
                    ],
                  ),
              ],
            ],
          ),
        ),
      );
    }

    final slot = widget.game.brewSlots[index];
    if (slot == null) {
      return GestureDetector(
        onTap: () => _showPotionSelection(context, index),
        child: Container(
          width: 80,
          height: 100,
          decoration: BoxDecoration(
            gradient: const LinearGradient(
              colors: [Color(0xFF4A3728), Color(0xFF2C1810)],
