    }

    if (item.currency == ShopCurrency.gold) {
      if (gold < item.price) return ["Not enough gold!"];
      gold -= item.price;
    } else {
      if (crystals < item.price) return ["Not enough crystals!"];
      crystals -= item.price;
    }

    item.onBuy(this);
    save();
    notifyListeners();
    return ["Acquired: ${item.name}"];
