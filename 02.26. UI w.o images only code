class WoodTexturePainter extends CustomPainter {
  final Color baseColor;

  WoodTexturePainter({this.baseColor = const Color(0xFF8B4513)});

  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = baseColor
      ..style = PaintingStyle.fill;

    // Base wood gradient
    final gradient = LinearGradient(
      begin: Alignment.topLeft,
      end: Alignment.bottomRight,
      colors: [
        baseColor.withLightness(1.2),
        baseColor,
        baseColor.withLightness(0.8),
      ],
    );

    final rect = Rect.fromLTWH(0, 0, size.width, size.height);
    paint.shader = gradient.createShader(rect);
    canvas.drawRect(rect, paint);

    // Wood grain lines
    final grainPaint = Paint()
      ..color = Colors.black.withOpacity(0.1)
      ..strokeWidth = 2
      ..style = PaintingStyle.stroke;

    for (int i = 0; i < size.height; i += 8) {
      final y = i.toDouble();
      final path = Path();
      path.moveTo(0, y);
      for (double x = 0; x < size.width; x += 20) {
        path.lineTo(x, y + sin(x * 0.05) * 3);
      }
      canvas.drawPath(path, grainPaint);
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
}

class PotionBottlePainter extends CustomPainter {
  final Color liquidColor;
  final double fillLevel;
  final bool isBubbling;

  PotionBottlePainter({
    required this.liquidColor,
    this.fillLevel = 0.7,
    this.isBubbling = false,
  });

  @override
  void paint(Canvas canvas, Size size) {
    final center = Offset(size.width / 2, size.height / 2);

    // Bottle shadow
    final shadowPaint = Paint()
      ..color = Colors.black.withOpacity(0.3)
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 8);
    canvas.drawOval(
      Rect.fromCenter(center: center.translate(4, 4), width: size.width * 0.8, height: size.height * 0.9),
      shadowPaint,
    );

    // Bottle body (rounded bottom)
    final bottlePath = Path()
      ..moveTo(size.width * 0.2, size.height * 0.3)
      ..lineTo(size.width * 0.2, size.height * 0.6)
      ..quadraticBezierTo(size.width * 0.2, size.height * 0.95, size.width * 0.5, size.height * 0.95)
      ..quadraticBezierTo(size.width * 0.8, size.height * 0.95, size.width * 0.8, size.height * 0.6)
      ..lineTo(size.width * 0.8, size.height * 0.3)
      ..close();

    // Glass effect
    final glassPaint = Paint()
      ..color = Colors.white.withOpacity(0.1)
      ..style = PaintingStyle.fill;
    canvas.drawPath(bottlePath, glassPaint);

    // Liquid
    if (fillLevel > 0) {
      final liquidHeight = size.height * 0.65 * fillLevel;
      final liquidPath = Path()
        ..moveTo(size.width * 0.22, size.height * 0.6 - liquidHeight + size.height * 0.35)
        ..lineTo(size.width * 0.22, size.height * 0.6)
        ..quadraticBezierTo(size.width * 0.22, size.height * 0.93, size.width * 0.5, size.height * 0.93)
        ..quadraticBezierTo(size.width * 0.78, size.height * 0.93, size.width * 0.78, size.height * 0.6)
        ..lineTo(size.width * 0.78, size.height * 0.6 - liquidHeight + size.height * 0.35)
        ..close();

      final liquidPaint = Paint()
        ..color = liquidColor
        ..style = PaintingStyle.fill;
      canvas.drawPath(liquidPath, liquidPaint);

      // Liquid shine
      final shinePaint = Paint()
        ..color = Colors.white.withOpacity(0.4)
        ..style = PaintingStyle.fill;
      canvas.drawOval(
        Rect.fromLTWH(size.width * 0.3, size.height * 0.5, size.width * 0.15, size.height * 0.3),
        shinePaint,
      );
    }

    // Bottle outline
    final outlinePaint = Paint()
      ..color = Colors.white.withOpacity(0.6)
      ..strokeWidth = 2
      ..style = PaintingStyle.stroke;
    canvas.drawPath(bottlePath, outlinePaint);

    // Neck
    final neckPath = Path()
      ..moveTo(size.width * 0.35, size.height * 0.3)
      ..lineTo(size.width * 0.35, size.height * 0.1)
      ..lineTo(size.width * 0.65, size.height * 0.1)
      ..lineTo(size.width * 0.65, size.height * 0.3)
      ..close();

    canvas.drawPath(neckPath, glassPaint);
    canvas.drawPath(neckPath, outlinePaint);

    // Cork
    final corkPaint = Paint()
      ..color = const Color(0xFF8B4513)
      ..style = PaintingStyle.fill;
    canvas.drawRect(
      Rect.fromLTWH(size.width * 0.32, size.height * 0.05, size.width * 0.36, size.height * 0.08),
      corkPaint,
    );
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
}

class BookPainter extends CustomPainter {
  final bool isOpen;

  BookPainter({this.isOpen = false});

  @override
  void paint(Canvas canvas, Size size) {
    if (!isOpen) {
      // Closed book
      final bookRect = RRect.fromRectAndRadius(
        Rect.fromLTWH(4, 4, size.width - 8, size.height - 8),
        const Radius.circular(4),
      );

      // Cover
      final coverPaint = Paint()
        ..color = const Color(0xFF5D4037)
        ..style = PaintingStyle.fill;
      canvas.drawRRect(bookRect, coverPaint);

      // Spine
      final spinePaint = Paint()
        ..color = const Color(0xFF3E2723)
        ..style = PaintingStyle.fill;
      canvas.drawRect(
        Rect.fromLTWH(size.width * 0.15, 4, size.width * 0.1, size.height - 8),
        spinePaint,
      );

      // Gold corners
      final goldPaint = Paint()
        ..color = MagicColors.gold
        ..style = PaintingStyle.fill;

      // Corner decorations
      canvas.drawCircle(Offset(size.width * 0.15, size.height * 0.15), 6, goldPaint);
      canvas.drawCircle(Offset(size.width * 0.15, size.height * 0.85), 6, goldPaint);
      canvas.drawCircle(Offset(size.width * 0.85, size.height * 0.15), 6, goldPaint);
      canvas.drawCircle(Offset(size.width * 0.85, size.height * 0.85), 6, goldPaint);

      // Center gem
      final gemPath = Path()
        ..moveTo(size.width * 0.5, size.height * 0.35)
        ..lineTo(size.width * 0.6, size.height * 0.5)
        ..lineTo(size.width * 0.5, size.height * 0.65)
        ..lineTo(size.width * 0.4, size.height * 0.5)
        ..close();

      final gemPaint = Paint()
        ..color = MagicColors.crystal
        ..style = PaintingStyle.fill;
      canvas.drawPath(gemPath, gemPaint);
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter painter) => false;
}

class DoorPainter extends CustomPainter {
  final bool isHovered;

  DoorPainter({this.isHovered = false});

  @override
  void paint(Canvas canvas, Size size) {
    // Door frame
    final framePaint = Paint()
      ..color = const Color(0xFF5D4037)
      ..style = PaintingStyle.fill;

    canvas.drawRRect(
      RRect.fromRectAndRadius(
        Rect.fromLTWH(0, 0, size.width, size.height),
        const Radius.circular(8),
      ),
      framePaint,
    );

    // Door panels
    final doorPaint = Paint()
      ..color = isHovered ? const Color(0xFF8D6E63) : const Color(0xFF6D4C41)
      ..style = PaintingStyle.fill;

    // Left panel
    canvas.drawRRect(
      RRect.fromRectAndRadius(
        Rect.fromLTWH(8, 8, size.width * 0.42, size.height - 16),
        const Radius.circular(4),
      ),
      doorPaint,
    );

    // Right panel
    canvas.drawRRect(
      RRect.fromRectAndRadius(
        Rect.fromLTWH(size.width * 0.5 + 2, 8, size.width * 0.42, size.height - 16),
        const Radius.circular(4),
      ),
      doorPaint,
    );

    // Door handles
    final handlePaint = Paint()
      ..color = MagicColors.gold
      ..style = PaintingStyle.fill;

    canvas.drawCircle(Offset(size.width * 0.38, size.height * 0.5), 6, handlePaint);
    canvas.drawCircle(Offset(size.width * 0.62, size.height * 0.5), 6, handlePaint);

    // Wood grain detail
    final grainPaint = Paint()
      ..color = Colors.black.withOpacity(0.2)
      ..strokeWidth = 1;

    for (double y = 20; y < size.height - 20; y += 15) {
      canvas.drawLine(Offset(12, y), Offset(size.width * 0.46, y), grainPaint);
      canvas.drawLine(Offset(size.width * 0.54, y), Offset(size.width - 12, y), grainPaint);
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
}

class GardenPlotPainter extends CustomPainter {
  final bool isPlanted;
  final double growthProgress;
  final Color plantColor;

  GardenPlotPainter({
    this.isPlanted = false,
    this.growthProgress = 0,
    this.plantColor = Colors.green,
  });

  @override
  void paint(Canvas canvas, Size size) {
    // Soil
    final soilPaint = Paint()
      ..color = const Color(0xFF5D4037)
      ..style = PaintingStyle.fill;

    canvas.drawOval(
      Rect.fromCenter(
        center: Offset(size.width / 2, size.height * 0.7),
        width: size.width * 0.9,
        height: size.height * 0.4,
      ),
      soilPaint,
    );

    // Soil texture
    final texturePaint = Paint()
      ..color = Colors.black.withOpacity(0.2)
      ..strokeWidth = 2;

    for (int i = 0; i < 5; i++) {
      final x = size.width * 0.2 + (size.width * 0.6 * i / 5);
      canvas.drawLine(
        Offset(x, size.height * 0.6),
        Offset(x + 5, size.height * 0.8),
        texturePaint,
      );
    }

    if (isPlanted && growthProgress > 0) {
      // Plant stem
      final stemPaint = Paint()
        ..color = plantColor.withDarkness(0.7)
        ..strokeWidth = 4
        ..style = PaintingStyle.stroke;

      final stemHeight = size.height * 0.5 * growthProgress;
      canvas.drawLine(
        Offset(size.width / 2, size.height * 0.7),
        Offset(size.width / 2, size.height * 0.7 - stemHeight),
        stemPaint,
      );

      // Leaves
      if (growthProgress > 0.3) {
        final leafPaint = Paint()
          ..color = plantColor
          ..style = PaintingStyle.fill;

        final leafSize = 15.0 * growthProgress;

        // Left leaf
        canvas.drawOval(
          Rect.fromCenter(
            center: Offset(size.width / 2 - 10, size.height * 0.5),
            width: leafSize,
            height: leafSize * 0.6,
          ),
          leafPaint,
        );

        // Right leaf
        canvas.drawOval(
          Rect.fromCenter(
            center: Offset(size.width / 2 + 10, size.height * 0.45),
            width: leafSize,
            height: leafSize * 0.6,
          ),
          leafPaint,
        );
      }

      // Flower/Top
      if (growthProgress > 0.7) {
        final flowerPaint = Paint()
          ..color = plantColor.withLightness(1.2)
          ..style = PaintingStyle.fill;

        canvas.drawCircle(
          Offset(size.width / 2, size.height * 0.2),
          12 * growthProgress,
          flowerPaint,
        );

        // Petals
        for (int i = 0; i < 5; i++) {
          final angle = (i * 72) * 3.14159 / 180;
          final petalX = size.width / 2 + cos(angle) * 15;
          final petalY = size.height * 0.2 + sin(angle) * 15;

          canvas.drawCircle(
            Offset(petalX, petalY),
            8 * growthProgress,
            flowerPaint,
          );
        }
      }
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

