  Widget _getScreen() {
    switch (screen) {
      case 0: return IdleBrewScreen(game);
      case 1: return IdleGardenScreen(game);
      case 2: return ShopScreen(game);
      case 3: return RecipeBookScreen(game);
      default: return IdleBrewScreen(game);
    }
  }
}

